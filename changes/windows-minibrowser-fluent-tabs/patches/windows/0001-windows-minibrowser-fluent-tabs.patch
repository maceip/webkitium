+
+void MainWindow::destroyModernMaterialBrushes()
+{
+    if (m_hToolbarFont) {
+        DeleteObject(m_hToolbarFont);
+        m_hToolbarFont = nullptr;
+    }
+    if (m_hURLBarFont) {
+        DeleteObject(m_hURLBarFont);
+        m_hURLBarFont = nullptr;
+    }
+    if (m_hToolbarBackgroundBrush) {
+        DeleteObject(m_hToolbarBackgroundBrush);
+        m_hToolbarBackgroundBrush = nullptr;
+    }
+    if (m_hEditBackgroundBrush) {
+        DeleteObject(m_hEditBackgroundBrush);
+        m_hEditBackgroundBrush = nullptr;
+    }
+    if (m_hWindowBackgroundBrush) {
+        DeleteObject(m_hWindowBackgroundBrush);
+        m_hWindowBackgroundBrush = nullptr;
+    }
+}
+
+HBRUSH MainWindow::toolbarBackgroundBrush()
+{
+    if (!m_hToolbarBackgroundBrush)
