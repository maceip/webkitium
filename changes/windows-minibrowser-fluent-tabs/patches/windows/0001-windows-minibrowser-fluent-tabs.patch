+static std::string utf8FromWideString(const std::wstring& string)
+{
+    if (string.empty())
+        return { };
+
+    int size = WideCharToMultiByte(CP_UTF8, 0, string.c_str(), static_cast<int>(string.length()), nullptr, 0, nullptr, nullptr);
+    if (size <= 0)
+        return { };
+
+    std::string result(size, '\0');
+    WideCharToMultiByte(CP_UTF8, 0, string.c_str(), static_cast<int>(string.length()), result.data(), size, nullptr, nullptr);
+    return result;
+}
