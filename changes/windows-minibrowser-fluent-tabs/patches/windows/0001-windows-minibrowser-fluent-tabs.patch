+#pragma once
+
+#include <optional>
+#include <string>
+#include <vector>
+
+namespace MiniBrowser {
+
+enum class TabStripMode {
+    Horizontal,
+    Vertical
+};
+
+struct VerticalTabStripState {
+    static constexpr int defaultUncollapsedWidth = 240;
+    static constexpr int minimumUncollapsedWidth = 160;
+    static constexpr int maximumUncollapsedWidth = 480;
+
+    bool collapsed { false };
+    int uncollapsedWidth { defaultUncollapsedWidth };
+};
+
+struct TabState {
+    int id { 0 };
+    std::string url;
+    std::string title;
+    bool loading { false };
+    bool canGoBack { false };
+    bool canGoForward { false };
+    bool pinned { false };
+    bool needsAttention { false };
+};
+
+class TabbedBrowsingModel {
+public:
+    class Observer {
+    public:
+        virtual void tabbedBrowsingModelDidChange(const TabbedBrowsingModel&) = 0;
+
+    protected:
+        virtual ~Observer() = default;
+    };
+
+    TabbedBrowsingModel();
+    TabbedBrowsingModel(const TabbedBrowsingModel&) = delete;
+    TabbedBrowsingModel& operator=(const TabbedBrowsingModel&) = delete;
+    ~TabbedBrowsingModel();
+
+    void addObserver(Observer&);
+    void removeObserver(Observer&);
+
+    int appendTab(std::string url, bool selected = true);
+    bool closeTab(int tabID);
+    bool selectTab(int tabID);
+    bool moveTab(int tabID, size_t destinationIndex);
+
+    bool setTabURL(int tabID, std::string);
+    bool setTabTitle(int tabID, std::string);
+    bool setTabLoadingState(int tabID, bool loading, bool canGoBack, bool canGoForward);
+    bool setTabPinned(int tabID, bool pinned);
+    bool setTabNeedsAttention(int tabID, bool needsAttention);
+
+    void setTabStripMode(TabStripMode);
+    void setVerticalTabStripCollapsed(bool);
+    void setVerticalTabStripUncollapsedWidth(int);
+
+    const std::vector<TabState>& tabs() const { return m_tabs; }
+    const TabState* tab(int tabID) const;
+    TabState* tab(int tabID);
+    const TabState* selectedTab() const;
+
+    std::optional<int> selectedTabID() const { return m_selectedTabID; }
+    TabStripMode tabStripMode() const { return m_tabStripMode; }
+    const VerticalTabStripState& verticalTabStripState() const { return m_verticalTabStripState; }
+
+    bool empty() const { return m_tabs.empty(); }
+    size_t size() const { return m_tabs.size(); }
+
+private:
+    using TabIterator = std::vector<TabState>::iterator;
+    using ConstTabIterator = std::vector<TabState>::const_iterator;
+
+    TabIterator findTab(int tabID);
+    ConstTabIterator findTab(int tabID) const;
+    size_t pinnedTabCount() const;
+    void enforcePinnedTabOrdering(int tabID);
+    void notifyChanged();
+
+    int m_nextTabID { 1 };
+    std::optional<int> m_selectedTabID;
+    TabStripMode m_tabStripMode { TabStripMode::Horizontal };
+    VerticalTabStripState m_verticalTabStripState;
+    std::vector<TabState> m_tabs;
+    std::vector<Observer*> m_observers;
+};
+
+} // namespace MiniBrowser
