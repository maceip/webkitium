+#include "TabbedBrowsingModel.h"
+
+#include <algorithm>
+#include <utility>
+
+namespace MiniBrowser {
+
+namespace {
+
+int clampVerticalWidth(int width)
+{
+    return std::clamp(width, VerticalTabStripState::minimumUncollapsedWidth, VerticalTabStripState::maximumUncollapsedWidth);
+}
+
+} // namespace
+
+TabbedBrowsingModel::TabbedBrowsingModel() = default;
+TabbedBrowsingModel::~TabbedBrowsingModel() = default;
+
+void TabbedBrowsingModel::addObserver(Observer& observer)
+{
+    if (std::find(m_observers.begin(), m_observers.end(), &observer) == m_observers.end())
+        m_observers.push_back(&observer);
+}
+
+void TabbedBrowsingModel::removeObserver(Observer& observer)
+{
+    m_observers.erase(std::remove(m_observers.begin(), m_observers.end(), &observer), m_observers.end());
+}
+
+int TabbedBrowsingModel::appendTab(std::string url, bool selected)
+{
+    TabState tab;
+    tab.id = m_nextTabID++;
+    tab.title = url.empty() ? "New Tab" : url;
+    tab.url = std::move(url);
+
+    const int tabID = tab.id;
+    m_tabs.push_back(std::move(tab));
+
+    if (selected || !m_selectedTabID)
+        m_selectedTabID = tabID;
+
+    notifyChanged();
+    return tabID;
+}
+
+bool TabbedBrowsingModel::closeTab(int tabID)
+{
+    auto iterator = findTab(tabID);
+    if (iterator == m_tabs.end())
+        return false;
+
+    const bool closedSelectedTab = m_selectedTabID == tabID;
+    const size_t closedIndex = static_cast<size_t>(std::distance(m_tabs.begin(), iterator));
+    m_tabs.erase(iterator);
+
+    if (m_tabs.empty())
+        m_selectedTabID.reset();
+    else if (closedSelectedTab)
+        m_selectedTabID = m_tabs[std::min(closedIndex, m_tabs.size() - 1)].id;
+
+    notifyChanged();
+    return true;
+}
+
+bool TabbedBrowsingModel::selectTab(int tabID)
+{
+    if (m_selectedTabID == tabID)
+        return true;
+
+    if (findTab(tabID) == m_tabs.end())
+        return false;
+
+    m_selectedTabID = tabID;
+    if (auto* selected = tab(tabID))
+        selected->needsAttention = false;
+
+    notifyChanged();
+    return true;
+}
+
+bool TabbedBrowsingModel::moveTab(int tabID, size_t destinationIndex)
+{
+    auto iterator = findTab(tabID);
+    if (iterator == m_tabs.end())
+        return false;
+
+    TabState movedTab = std::move(*iterator);
+    const bool movedPinnedTab = movedTab.pinned;
+    m_tabs.erase(iterator);
+
+    const size_t firstUnpinnedIndex = pinnedTabCount();
+    if (movedPinnedTab)
+        destinationIndex = std::min(destinationIndex, firstUnpinnedIndex);
+    else
+        destinationIndex = std::max(destinationIndex, firstUnpinnedIndex);
+
+    destinationIndex = std::min(destinationIndex, m_tabs.size());
+    m_tabs.insert(m_tabs.begin() + destinationIndex, std::move(movedTab));
+
+    notifyChanged();
+    return true;
+}
+
+bool TabbedBrowsingModel::setTabURL(int tabID, std::string url)
+{
+    auto* target = tab(tabID);
+    if (!target)
+        return false;
+
+    target->url = std::move(url);
+    notifyChanged();
+    return true;
+}
+
+bool TabbedBrowsingModel::setTabTitle(int tabID, std::string title)
+{
+    auto* target = tab(tabID);
+    if (!target)
+        return false;
+
+    target->title = std::move(title);
+    notifyChanged();
+    return true;
+}
+
+bool TabbedBrowsingModel::setTabLoadingState(int tabID, bool loading, bool canGoBack, bool canGoForward)
+{
+    auto* target = tab(tabID);
+    if (!target)
+        return false;
+
+    target->loading = loading;
+    target->canGoBack = canGoBack;
+    target->canGoForward = canGoForward;
+    notifyChanged();
+    return true;
+}
+
+bool TabbedBrowsingModel::setTabPinned(int tabID, bool pinned)
+{
+    auto* target = tab(tabID);
+    if (!target)
+        return false;
+
+    if (target->pinned == pinned)
+        return true;
+
+    target->pinned = pinned;
+    enforcePinnedTabOrdering(tabID);
+    notifyChanged();
+    return true;
+}
+
+bool TabbedBrowsingModel::setTabNeedsAttention(int tabID, bool needsAttention)
+{
+    auto* target = tab(tabID);
+    if (!target)
+        return false;
+
+    target->needsAttention = needsAttention && m_selectedTabID != tabID;
+    notifyChanged();
+    return true;
+}
+
+void TabbedBrowsingModel::setTabStripMode(TabStripMode mode)
+{
+    if (m_tabStripMode == mode)
+        return;
+
+    m_tabStripMode = mode;
+    notifyChanged();
+}
+
+void TabbedBrowsingModel::setVerticalTabStripCollapsed(bool collapsed)
+{
+    if (m_verticalTabStripState.collapsed == collapsed)
+        return;
+
+    m_verticalTabStripState.collapsed = collapsed;
+    notifyChanged();
+}
+
+void TabbedBrowsingModel::setVerticalTabStripUncollapsedWidth(int width)
+{
+    const int clampedWidth = clampVerticalWidth(width);
+    if (m_verticalTabStripState.uncollapsedWidth == clampedWidth)
+        return;
+
+    m_verticalTabStripState.uncollapsedWidth = clampedWidth;
+    notifyChanged();
+}
+
+const TabState* TabbedBrowsingModel::tab(int tabID) const
+{
+    auto iterator = findTab(tabID);
+    return iterator == m_tabs.end() ? nullptr : &*iterator;
+}
+
+TabState* TabbedBrowsingModel::tab(int tabID)
+{
+    auto iterator = findTab(tabID);
+    return iterator == m_tabs.end() ? nullptr : &*iterator;
+}
+
+const TabState* TabbedBrowsingModel::selectedTab() const
+{
+    return m_selectedTabID ? tab(*m_selectedTabID) : nullptr;
+}
+
+TabbedBrowsingModel::TabIterator TabbedBrowsingModel::findTab(int tabID)
+{
+    return std::find_if(m_tabs.begin(), m_tabs.end(), [tabID](const auto& tab) {
+        return tab.id == tabID;
+    });
+}
+
+TabbedBrowsingModel::ConstTabIterator TabbedBrowsingModel::findTab(int tabID) const
+{
+    return std::find_if(m_tabs.begin(), m_tabs.end(), [tabID](const auto& tab) {
+        return tab.id == tabID;
+    });
+}
+
+size_t TabbedBrowsingModel::pinnedTabCount() const
+{
+    return static_cast<size_t>(std::count_if(m_tabs.begin(), m_tabs.end(), [](const auto& tab) {
+        return tab.pinned;
+    }));
+}
+
+void TabbedBrowsingModel::enforcePinnedTabOrdering(int tabID)
+{
+    auto iterator = findTab(tabID);
+    if (iterator == m_tabs.end())
+        return;
+
+    const bool pinned = iterator->pinned;
+    size_t targetIndex = pinned ? pinnedTabCount() - 1 : pinnedTabCount();
+    TabState movedTab = std::move(*iterator);
+    m_tabs.erase(iterator);
+
+    targetIndex = std::min(targetIndex, m_tabs.size());
+    m_tabs.insert(m_tabs.begin() + targetIndex, std::move(movedTab));
+}
+
+void TabbedBrowsingModel::notifyChanged()
+{
+    auto observers = m_observers;
+    for (auto* observer : observers) {
+        if (std::find(m_observers.begin(), m_observers.end(), observer) != m_observers.end())
+            observer->tabbedBrowsingModelDidChange(*this);
+    }
+}
+
+} // namespace MiniBrowser
