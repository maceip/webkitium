+/*
+ * Windows WebNN backend using ONNX Runtime.
+ *
+ * ONNX Runtime is the primary inference engine for WebNN on Windows.
+ * On Windows 11 24H2+, it uses the Windows ML infrastructure.
+ * On older Windows, it falls back to DirectML (GPU) or CPU EP.
+ */
+
+#pragma once
+
+#if ENABLE(WEBNN) && PLATFORM(WIN) && HAVE(ONNXRUNTIME)
+
+#include "WebNNContextImpl.h"
+#include "MLContextOptions.h"
+
+struct OrtApi;
+struct OrtEnv;
+struct OrtSessionOptions;
+struct OrtMemoryInfo;
+struct OrtAllocator;
+
+namespace WebCore {
+namespace WebNN {
+
+class WindowsOnnxRTGraph;
+
+class WindowsOnnxRTContext final : public WebNNContextImpl {
+public:
+    static std::unique_ptr<WindowsOnnxRTContext> create(
+        const MLContextOptions&);
+    ~WindowsOnnxRTContext() override;
+
+    MLDevicePreference devicePreference() const override { return m_device; }
+
+    RefPtr<MLTensor> createTensor(MLTensorDescriptor&&) override;
+    void writeTensor(MLTensor&, const void* data, size_t byteLength) override;
+    void readTensor(MLTensor&,
+                    std::function<void(RefPtr<ArrayBuffer>)>&&) override;
+
+    void dispatch(WebNNGraphImpl&,
+                  HashMap<String, RefPtr<MLTensor>>& inputs,
+                  HashMap<String, RefPtr<MLTensor>>& outputs,
+                  std::function<void(bool)>&&) override;
+
+    std::unique_ptr<WebNNGraphImpl> buildGraph(
+        HashMap<String, RefPtr<MLOperand>>& outputs) override;
+
+    const OrtApi* ortApi() const { return m_api; }
+    OrtEnv* ortEnv() const { return m_env; }
+
+private:
+    explicit WindowsOnnxRTContext(MLDevicePreference);
+
+    bool initialize();
+
+    const OrtApi* m_api { nullptr };
+    OrtEnv* m_env { nullptr };
+    OrtSessionOptions* m_defaultSessionOptions { nullptr };
+    OrtMemoryInfo* m_cpuMemoryInfo { nullptr };
+    MLDevicePreference m_device { MLDevicePreference::CPU };
+    bool m_initialized { false };
+};
+
+} // namespace WebNN
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN) && PLATFORM(WIN) && HAVE(ONNXRUNTIME)
diff --git a/Source/WebCore/Modules/WebNN/Implementation/WebNNWindowsOnnxRT.cpp b/Source/WebCore/Modules/WebNN/Implementation/WebNNWindowsOnnxRT.cpp
