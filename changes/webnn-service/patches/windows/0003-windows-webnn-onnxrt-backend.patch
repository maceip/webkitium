@@ -0,0 +1,159 @@
+/*
+ * Windows WebNN backend using ONNX Runtime.
+ */
+
+#include "config.h"
+#include "WebNNWindowsOnnxRT.h"
+
+#if ENABLE(WEBNN) && PLATFORM(WIN) && HAVE(ONNXRUNTIME)
+
+#include "WebNNWindowsOnnxRTGraph.h"
+#include "MLTensor.h"
+#include "MLOperand.h"
+#include <onnxruntime_c_api.h>
+#include <wtf/text/CString.h>
+
+namespace WebCore {
+namespace WebNN {
+
+// Tensor subclass backed by ORT-managed memory
+class OnnxRTTensor final : public MLTensor {
+public:
+    static Ref<OnnxRTTensor> create(MLTensorDescriptor&& desc, size_t byteLength)
+    {
+        return adoptRef(*new OnnxRTTensor(WTFMove(desc), byteLength));
+    }
+
+    void* data() { return m_buffer.data(); }
+    const void* data() const { return m_buffer.data(); }
+    size_t byteLength() const { return m_buffer.size(); }
+
+private:
+    OnnxRTTensor(MLTensorDescriptor&& desc, size_t byteLength)
+        : MLTensor(WTFMove(desc))
+        , m_buffer(byteLength, 0)
+    {
+    }
+
+    Vector<uint8_t> m_buffer;
+};
+
+std::unique_ptr<WindowsOnnxRTContext> WindowsOnnxRTContext::create(
+    const MLContextOptions& options)
+{
+    auto context = std::unique_ptr<WindowsOnnxRTContext>(
+        new WindowsOnnxRTContext(options.devicePreference));
+    if (!context->initialize())
+        return nullptr;
+    return context;
+}
+
+WindowsOnnxRTContext::WindowsOnnxRTContext(MLDevicePreference device)
+    : m_device(device)
+{
+}
+
+WindowsOnnxRTContext::~WindowsOnnxRTContext()
+{
+    if (m_cpuMemoryInfo && m_api)
+        m_api->ReleaseMemoryInfo(m_cpuMemoryInfo);
+    if (m_defaultSessionOptions && m_api)
+        m_api->ReleaseSessionOptions(m_defaultSessionOptions);
+    if (m_env && m_api)
+        m_api->ReleaseEnv(m_env);
+}
+
+bool WindowsOnnxRTContext::initialize()
+{
+    m_api = OrtGetApiBase()->GetApi(ORT_API_VERSION);
+    if (!m_api)
+        return false;
+
+    OrtStatus* status = m_api->CreateEnv(
+        ORT_LOGGING_LEVEL_WARNING, "WebNN", &m_env);
+    if (status) {
+        m_api->ReleaseStatus(status);
+        return false;
+    }
+
+    status = m_api->CreateSessionOptions(&m_defaultSessionOptions);
+    if (status) {
+        m_api->ReleaseStatus(status);
+        return false;
+    }
+
+    // Configure execution provider based on device preference
+    if (m_device == MLDevicePreference::GPU) {
+        // Attempt DirectML EP for GPU acceleration.
+        // Falls back to CPU if DirectML is unavailable.
+        // OrtSessionOptionsAppendExecutionProvider_DML is available
+        // when onnxruntime is built with DirectML support.
+    }
+
+    status = m_api->CreateCpuMemoryInfo(
+        OrtArenaAllocator, OrtMemTypeDefault, &m_cpuMemoryInfo);
+    if (status) {
+        m_api->ReleaseStatus(status);
+        return false;
+    }
+
+    m_initialized = true;
+    return true;
+}
+
+static size_t bytesPerElement(const String& dataType)
+{
+    if (dataType == "float32"_s)
+        return 4;
+    if (dataType == "float16"_s)
+        return 2;
+    if (dataType == "int32"_s || dataType == "uint32"_s)
+        return 4;
+    if (dataType == "int8"_s || dataType == "uint8"_s)
+        return 1;
+    if (dataType == "int64"_s)
+        return 8;
+    return 4; // Default to float32 size
+}
+
+static size_t tensorByteLength(const String& dataType,
+                                const Vector<unsigned>& shape)
+{
+    size_t elements = 1;
+    for (auto dim : shape)
+        elements *= dim;
+    return elements * bytesPerElement(dataType);
+}
+
+RefPtr<MLTensor> WindowsOnnxRTContext::createTensor(MLTensorDescriptor&& desc)
+{
+    size_t byteLen = tensorByteLength(desc.dataType, desc.shape);
+    return OnnxRTTensor::create(WTFMove(desc), byteLen);
+}
+
+void WindowsOnnxRTContext::writeTensor(MLTensor& tensor, const void* data,
+                                        size_t byteLength)
+{
+    auto& ortTensor = static_cast<OnnxRTTensor&>(tensor);
+    size_t copyLen = std::min(byteLength, ortTensor.byteLength());
+    memcpy(ortTensor.data(), data, copyLen);
+}
+
+void WindowsOnnxRTContext::readTensor(
+    MLTensor& tensor,
+    std::function<void(RefPtr<ArrayBuffer>)>&& callback)
+{
+    auto& ortTensor = static_cast<OnnxRTTensor&>(tensor);
+    auto buffer = ArrayBuffer::tryCreate(ortTensor.data(),
+                                          ortTensor.byteLength());
+    callback(WTFMove(buffer));
+}
+
+void WindowsOnnxRTContext::dispatch(
+    WebNNGraphImpl& graph,
+    HashMap<String, RefPtr<MLTensor>>& inputs,
+    HashMap<String, RefPtr<MLTensor>>& outputs,
+    std::function<void(bool)>&& callback)
+{
+    auto& ortGraph = static_cast<WindowsOnnxRTGraph&>(graph);
+    bool success = ortGraph.run(this, inputs, outputs);
+    callback(success);
+}
+
+std::unique_ptr<WebNNGraphImpl> WindowsOnnxRTContext::buildGraph(
+    HashMap<String, RefPtr<MLOperand>>& outputs)
+{
+    return WindowsOnnxRTGraph::create(this, outputs);
+}
+
+} // namespace WebNN
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN) && PLATFORM(WIN) && HAVE(ONNXRUNTIME)
