+/*
+ * Windows WebNN compiled graph backed by an ONNX Runtime session.
+ */
+
+#pragma once
+
+#if ENABLE(WEBNN) && PLATFORM(WIN) && HAVE(ONNXRUNTIME)
+
+#include "WebNNGraphImpl.h"
+#include "MLOperand.h"
+#include "MLTensor.h"
+#include <wtf/HashMap.h>
+#include <wtf/RefPtr.h>
+#include <wtf/text/WTFString.h>
+#include <memory>
+
+struct OrtSession;
+struct OrtValue;
+
+namespace WebCore {
+namespace WebNN {
+
+class WindowsOnnxRTContext;
+
+class WindowsOnnxRTGraph final : public WebNNGraphImpl {
+public:
+    static std::unique_ptr<WindowsOnnxRTGraph> create(
+        WindowsOnnxRTContext*,
+        HashMap<String, RefPtr<MLOperand>>& outputs);
+
+    ~WindowsOnnxRTGraph() override;
+
+    void* backendHandle() const override { return m_session; }
+
+    bool run(WindowsOnnxRTContext*,
+             HashMap<String, RefPtr<MLTensor>>& inputs,
+             HashMap<String, RefPtr<MLTensor>>& outputs);
+
+private:
+    WindowsOnnxRTGraph();
+
+    bool buildFromOperands(WindowsOnnxRTContext*,
+                           HashMap<String, RefPtr<MLOperand>>& outputs);
+
+    OrtSession* m_session { nullptr };
+    Vector<String> m_inputNames;
+    Vector<String> m_outputNames;
+};
+
+} // namespace WebNN
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN) && PLATFORM(WIN) && HAVE(ONNXRUNTIME)
diff --git a/Source/WebCore/Modules/WebNN/Implementation/WebNNWindowsOnnxRTGraph.cpp b/Source/WebCore/Modules/WebNN/Implementation/WebNNWindowsOnnxRTGraph.cpp
