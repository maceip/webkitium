@@ -0,0 +1,88 @@
+/*
+ * Windows WebNN compiled graph backed by an ONNX Runtime session.
+ *
+ * The graph builder constructs operations as MLOperand nodes. When
+ * build() is called, these are translated to an ONNX model proto
+ * (or ONNX Runtime's graph builder API) and compiled into an
+ * OrtSession.
+ *
+ * First milestone: prove the lifecycle (create session, bind I/O,
+ * run). Full op translation follows.
+ */
+
+#include "config.h"
+#include "WebNNWindowsOnnxRTGraph.h"
+
+#if ENABLE(WEBNN) && PLATFORM(WIN) && HAVE(ONNXRUNTIME)
+
+#include "WebNNWindowsOnnxRT.h"
+#include "MLOperand.h"
+#include "MLTensor.h"
+#include <onnxruntime_c_api.h>
+
+namespace WebCore {
+namespace WebNN {
+
+WindowsOnnxRTGraph::WindowsOnnxRTGraph() = default;
+
+WindowsOnnxRTGraph::~WindowsOnnxRTGraph()
+{
+    // OrtSession is owned by the runtime; release via API
+    // m_session cleanup handled by the ORT API if needed
+}
+
+std::unique_ptr<WindowsOnnxRTGraph> WindowsOnnxRTGraph::create(
+    WindowsOnnxRTContext* context,
+    HashMap<String, RefPtr<MLOperand>>& outputs)
+{
+    auto graph = std::unique_ptr<WindowsOnnxRTGraph>(
+        new WindowsOnnxRTGraph());
+    if (!graph->buildFromOperands(context, outputs))
+        return nullptr;
+    return graph;
+}
+
+bool WindowsOnnxRTGraph::buildFromOperands(
+    WindowsOnnxRTContext* context,
+    HashMap<String, RefPtr<MLOperand>>& outputs)
+{
+    if (!context || !context->ortApi() || !context->ortEnv())
+        return false;
+
+    // Collect output names
+    for (auto& [name, operand] : outputs) {
+        if (operand)
+            m_outputNames.append(name);
+    }
+
+    // Milestone 1: Graph construction from MLOperand tree → ORT session
+    // is not yet implemented. This stub validates the lifecycle:
+    // context.buildGraph() → graph object → context.dispatch(graph, ...)
+    //
+    // Full implementation will:
+    // 1. Walk the MLOperand DAG from outputs back to inputs.
+    // 2. Translate each MLOperand operation to an ONNX NodeProto.
+    // 3. Serialize to an ONNX ModelProto byte buffer.
+    // 4. Create an OrtSession from the in-memory model.
+
+    return true;
+}
+
+bool WindowsOnnxRTGraph::run(
+    WindowsOnnxRTContext* context,
+    HashMap<String, RefPtr<MLTensor>>& inputs,
+    HashMap<String, RefPtr<MLTensor>>& outputs)
+{
+    if (!context || !context->ortApi())
+        return false;
+
+    // Milestone 1 stub: validates dispatch lifecycle without executing
+    // a real model. Full implementation will:
+    // 1. Create OrtValue wrappers around MLTensor data buffers.
+    // 2. Call OrtRun with bound input/output OrtValues.
+    // 3. Copy results back to output MLTensors if needed.
+
+    if (!m_session) {
+        // No compiled session yet — lifecycle-only validation
+        return true;
+    }
+
+    return true;
+}
+
+} // namespace WebNN
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN) && PLATFORM(WIN) && HAVE(ONNXRUNTIME)
