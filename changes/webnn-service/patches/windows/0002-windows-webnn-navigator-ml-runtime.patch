--- /dev/null
+++ b/Source/WebCore/Modules/WebNN/ML.cpp
@@ -0,0 +1,50 @@
+/*
+ * Copyright (C) 2024–2026 Webkitium Contributors
+ */
+
+#include "config.h"
+#include "ML.h"
+
+#if ENABLE(WEBNN)
+
+#include "MLContext.h"
+#include "MLContextOptions.h"
+#include "JSDOMPromiseDeferred.h"
+
+#if HAVE(LITERT)
+#include "WebNNLiteRTContext.h"
+#endif
+
+namespace WebCore {
+
+Ref<ML> ML::create(Navigator& navigator)
+{
+    return adoptRef(*new ML(navigator));
+}
+
+ML::ML(Navigator& navigator)
+    : m_navigator(navigator)
+{
+}
+
+ML::~ML() = default;
+
+void ML::createContext(MLContextOptions&& options, Ref<DeferredPromise>&& promise)
+{
+#if HAVE(LITERT)
+    auto context = WebNN::LiteRTContext::create(options);
+    if (!context) {
+        promise->reject(Exception { ExceptionCode::NotSupportedError,
+            "Failed to create WebNN context with LiteRT backend"_s });
+        return;
+    }
+    promise->resolve<IDLInterface<MLContext>>(*context);
+#else
+    promise->reject(Exception { ExceptionCode::NotSupportedError,
+        "WebNN is not supported on this platform"_s });
+#endif
+}
+
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN)
