+/*
+ * https://webmachinelearning.github.io/webnn/#api-ml
+ */
+
+[
+    Conditional=WEBNN,
+    Exposed=Window,
+    SecureContext
+] interface ML {
+    [NewObject] Promise<MLContext> createContext(optional MLContextOptions options = {});
+
+    // Future: createContext(GPUDevice gpuDevice) for WebGPU interop
+};
