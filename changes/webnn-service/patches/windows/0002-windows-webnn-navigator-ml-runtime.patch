+++ b/Source/WebCore/Modules/WebNN/NavigatorML.cpp
@@ -0,0 +1,57 @@
+/*
+ * Copyright (C) 2024-2026 Webkitium Contributors
+ */
+
+#include "config.h"
+#include "Modules/WebNN/NavigatorML.h"
+
+#if ENABLE(WEBNN)
+
+#include "Modules/WebNN/ML.h"
+#include "page/Navigator.h"
+#include <wtf/TZoneMallocInlines.h>
+#include <wtf/StdLibExtras.h>
+
+namespace WebCore {
+
+WTF_MAKE_TZONE_ALLOCATED_IMPL(NavigatorML);
+
+NavigatorML::NavigatorML(Navigator& navigator)
+    : m_navigator(navigator)
+{
+}
+
+NavigatorML::~NavigatorML() = default;
+
+ASCIILiteral NavigatorML::supplementName()
+{
+    return "NavigatorML"_s;
+}
+
+NavigatorML* NavigatorML::from(Navigator& navigator)
+{
+    auto* supplement = static_cast<NavigatorML*>(
+        Supplement<Navigator>::from(&navigator, supplementName()));
+    if (!supplement) {
+        auto newSupplement = makeUnique<NavigatorML>(navigator);
+        supplement = newSupplement.get();
+        provideTo(&navigator, supplementName(), WTF::move(newSupplement));
+    }
+    return supplement;
+}
+
+ML* NavigatorML::ml(Navigator& navigator)
+{
+    return NavigatorML::from(navigator)->ml();
+}
+
+ML* NavigatorML::ml()
+{
+    if (!m_ml)
+        m_ml = ML::create(m_navigator);
+    return m_ml.get();
+}
+
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN)
