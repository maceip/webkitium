diff --git a/Source/WebCore/Modules/WebNN/ML.cpp b/Source/WebCore/Modules/WebNN/ML.cpp
new file mode 100644
index 0000000000..18a6ce387c
--- /dev/null
+++ b/Source/WebCore/Modules/WebNN/ML.cpp
@@ -0,0 +1,61 @@
+/*
+ * Copyright (C) 2024-2026 Webkitium Contributors
+ */
+
+#include "config.h"
+#include "Modules/WebNN/ML.h"
+
+#if ENABLE(WEBNN)
+
+#include "Modules/WebNN/MLContext.h"
+#include "Modules/WebNN/MLContextOptions.h"
+#include "Modules/WebNN/Implementation/LiteRTLoader.h"
+#include "Modules/WebNN/Implementation/WebNNLiteRTContext.h"
+#include "bindings/js/JSDOMConvertInterface.h"
+#include "bindings/js/JSDOMPromiseDeferred.h"
+#include "JSMLContext.h"
+#include <wtf/StdLibExtras.h>
+
+namespace WebCore {
+
+Ref<ML> ML::create(Navigator& navigator)
+{
+    UNUSED_PARAM(navigator);
+    return adoptRef(*new ML(navigator));
+}
+
+ML::ML(Navigator&)
+{
+}
+
+ML::~ML() = default;
+
+void ML::createContext(MLContextOptions&& options, Ref<DeferredPromise>&& promise)
+{
+    auto& loader = WebNN::LiteRTLoader::singleton();
+    if (!loader.isLoaded()) {
+        promise->reject(Exception { ExceptionCode::NotSupportedError,
+            "WebNN: LiteRT runtime library not available"_s });
+        return;
+    }
+
+    auto backendContext = WebNN::LiteRTContext::create(options);
+    if (!backendContext) {
+        promise->reject(Exception { ExceptionCode::NotSupportedError,
+            "WebNN: failed to create ML context"_s });
+        return;
+    }
+
+    auto mlContext = MLContext::create(WTF::move(backendContext));
+    if (!mlContext) {
+        promise->reject(Exception { ExceptionCode::NotSupportedError,
+            "WebNN: failed to wrap ML context"_s });
+        return;
+    }
+
+    promise->resolveWithNewlyCreated<IDLInterface<MLContext>>(mlContext.releaseNonNull());
+}
+
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN)
