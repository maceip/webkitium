diff --git a/Source/cmake/FindLiteRT.cmake b/Source/cmake/FindLiteRT.cmake
new file mode 100644
index 00000000000..a1b2c3d4e5f
--- /dev/null
+++ b/Source/cmake/FindLiteRT.cmake
@@ -0,0 +1,89 @@
+# FindLiteRT.cmake
+#
+# Finds the LiteRT-LM library for WebNN backend support.
+# LiteRT-LM is Google's production-ready C++ inference framework
+# (successor to TFLite) that provides unified cross-platform ML inference.
+#
+# This will define:
+#   LiteRT_FOUND        - True if LiteRT-LM is available
+#   LiteRT_INCLUDE_DIRS - Include directories
+#   LiteRT_LIBRARIES    - Libraries to link
+#   LiteRT_VERSION      - Version string
+
+include(FindPackageHandleStandardArgs)
+
+# Try pre-built library first
+find_path(LiteRT_INCLUDE_DIR
+    NAMES runtime/engine/engine.h
+    PATH_SUFFIXES litert-lm litert_lm
+)
+
+# Fall back to TFLite header path (LiteRT core)
+if (NOT LiteRT_INCLUDE_DIR)
+    find_path(LiteRT_INCLUDE_DIR
+        NAMES tensorflow/lite/interpreter.h
+        PATH_SUFFIXES tflite litert
+    )
+endif ()
+
+# LiteRT core library (prebuilt name is libLiteRt on all platforms)
+if (WIN32)
+    # Prebuilt ships as libLiteRt.dll with no import lib; find the DLL directly
+    set(_litert_saved_suffixes ${CMAKE_FIND_LIBRARY_SUFFIXES})
+    set(CMAKE_FIND_LIBRARY_SUFFIXES .dll .lib)
+endif ()
+find_library(LiteRT_LIBRARY
+    NAMES libLiteRt LiteRt litert_lm litert-lm tensorflow-lite tflite
+)
+if (WIN32)
+    set(CMAKE_FIND_LIBRARY_SUFFIXES ${_litert_saved_suffixes})
+endif ()
+
+# GPU accelerator (platform-specific, optional)
+find_library(LiteRT_GPU_LIBRARY
+    NAMES LiteRtMetalAccelerator LiteRtGpuAccelerator LiteRtOpenClAccelerator
+)
+
+# XNNPACK delegate (CPU acceleration — bundled in LiteRT core on most platforms)
+find_library(LiteRT_XNNPACK_LIBRARY
+    NAMES xnnpack XNNPACK
+)
+
+find_package_handle_standard_args(LiteRT
+    REQUIRED_VARS LiteRT_LIBRARY LiteRT_INCLUDE_DIR
+)
+
+if (LiteRT_FOUND)
+    set(LiteRT_INCLUDE_DIRS ${LiteRT_INCLUDE_DIR})
+    set(LiteRT_LIBRARIES ${LiteRT_LIBRARY})
+    if (LiteRT_GPU_LIBRARY)
+        list(APPEND LiteRT_LIBRARIES ${LiteRT_GPU_LIBRARY})
+        SET_AND_EXPOSE_TO_BUILD(HAVE_LITERT_GPU_DELEGATE ON)
+    endif ()
+    if (LiteRT_XNNPACK_LIBRARY)
+        list(APPEND LiteRT_LIBRARIES ${LiteRT_XNNPACK_LIBRARY})
+    endif ()
+endif ()
+
+mark_as_advanced(LiteRT_INCLUDE_DIR LiteRT_LIBRARY LiteRT_XNNPACK_LIBRARY)
+
+# Option to build from source via ExternalProject
+option(LITERT_BUILD_FROM_SOURCE
+    "Build LiteRT-LM from source instead of using pre-built library" OFF)
+
+if (LITERT_BUILD_FROM_SOURCE AND NOT LiteRT_FOUND)
+    include(ExternalProject)
+    ExternalProject_Add(litert_lm_build
+        GIT_REPOSITORY https://github.com/google-ai-edge/LiteRT-LM.git
+        GIT_TAG v0.10.2
+        SOURCE_DIR ${CMAKE_BINARY_DIR}/litert-lm-src
+        BINARY_DIR ${CMAKE_BINARY_DIR}/litert-lm-build
+        CMAKE_ARGS
+            -DLITERTLM_PROJECT_ROOT=${CMAKE_BINARY_DIR}/litert-lm-src
+        INSTALL_COMMAND ""
+        BUILD_ALWAYS FALSE
+    )
+    set(LiteRT_INCLUDE_DIRS ${CMAKE_BINARY_DIR}/litert-lm-src)
+    set(LiteRT_LIBRARIES ${CMAKE_BINARY_DIR}/litert-lm-build/litert_lm)
+    set(LiteRT_FOUND TRUE)
+endif ()
+endif ()
