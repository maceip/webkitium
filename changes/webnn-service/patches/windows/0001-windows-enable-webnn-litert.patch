diff --git a/Source/cmake/FindLiteRT.cmake b/Source/cmake/FindLiteRT.cmake
new file mode 100644
index 00000000000..a1b2c3d4e5f
--- /dev/null
+++ b/Source/cmake/FindLiteRT.cmake
@@ -0,0 +1,41 @@
+# FindLiteRT.cmake
+#
+# WebNN backend uses LiteRT (TFLite successor) via RUNTIME LOADING.
+# We do NOT link against libLiteRt at build time because the prebuilt
+# ships as a DLL with no import .lib on Windows.
+#
+# Instead, LiteRTLoader.cpp uses LoadLibrary/dlopen + GetProcAddress/dlsym
+# to resolve the TFLite C API functions at runtime. This means:
+# - No LiteRT_LIBRARY is needed at link time
+# - No TFLite headers are needed at compile time (we define our own types)
+# - The DLL/dylib/so just needs to be beside the browser binary at runtime
+#
+# This module only verifies the DLL can be found for packaging purposes.
+
+# Check if the DLL/so/dylib exists beside the build output for packaging
+if (WIN32)
+    find_file(LiteRT_DLL
+        NAMES libLiteRt.dll LiteRt.dll
+        PATHS "${CMAKE_BINARY_DIR}" "${CMAKE_RUNTIME_OUTPUT_DIRECTORY}"
+        NO_DEFAULT_PATH
+    )
+    if (LiteRT_DLL)
+        message(STATUS "LiteRT DLL found for packaging: ${LiteRT_DLL}")
+    else ()
+        message(STATUS "LiteRT DLL not found at build time — will be loaded at runtime from beside the browser binary")
+    endif ()
+elseif (APPLE)
+    find_file(LiteRT_DYLIB
+        NAMES libLiteRt.dylib
+    )
+else ()
+    find_file(LiteRT_SO
+        NAMES libLiteRt.so
+    )
+endif ()
+
+# Always set LiteRT_FOUND to TRUE — the actual loading happens at runtime
+# via LiteRTLoader. If the DLL is missing at runtime, navigator.ml will
+# gracefully return null instead of crashing.
+set(LiteRT_FOUND TRUE)
+SET_AND_EXPOSE_TO_BUILD(HAVE_LITERT ON)
