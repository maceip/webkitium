+/*
+ * https://webmachinelearning.github.io/webnn/#api-mltensor
+ */
+
+#pragma once
+
+#if ENABLE(WEBNN)
+
+#include <wtf/Ref.h>
+#include <wtf/RefCounted.h>
+#include <wtf/Vector.h>
+#include <wtf/text/WTFString.h>
+
+namespace WebCore {
+
+struct MLTensorDescriptor {
+    String dataType;
+    Vector<unsigned> shape;
+    bool readable { false };
+    bool writable { false };
+};
+
+class MLTensor : public RefCounted<MLTensor> {
+public:
+    static Ref<MLTensor> create(MLTensorDescriptor&&);
+    virtual ~MLTensor();
+
+    const String& dataType() const { return m_dataType; }
+    const Vector<unsigned>& shape() const { return m_shape; }
+    bool readable() const { return m_readable; }
+    bool writable() const { return m_writable; }
+
+    void destroy();
+
+    virtual void* backendHandle() const { return nullptr; }
+
+protected:
+    explicit MLTensor(MLTensorDescriptor&&);
+
+    String m_dataType;
+    Vector<unsigned> m_shape;
+    bool m_readable { false };
+    bool m_writable { false };
+    bool m_destroyed { false };
+};
+
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN)
