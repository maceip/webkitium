diff --git a/Source/WebCore/Modules/WebNN/MLContext.h b/Source/WebCore/Modules/WebNN/MLContext.h
new file mode 100644
index 0000000000..939b503394
--- /dev/null
+++ b/Source/WebCore/Modules/WebNN/MLContext.h
@@ -0,0 +1,56 @@
+/*
+ * https://webmachinelearning.github.io/webnn/#api-mlcontext
+ */
+
+#pragma once
+
+#if ENABLE(WEBNN)
+
+#include "Modules/WebNN/MLContextOptions.h"
+#include <wtf/Ref.h>
+#include <wtf/RefCounted.h>
+#include <wtf/RefPtr.h>
+#include <wtf/HashMap.h>
+#include <wtf/text/WTFString.h>
+
+namespace WebCore {
+
+class MLGraph;
+class MLTensor;
+struct MLTensorDescriptor;
+class DeferredPromise;
+class ArrayBuffer;
+
+namespace WebNN {
+class WebNNContextImpl;
+}
+
+using MLNamedTensors = HashMap<String, RefPtr<MLTensor>>;
+
+class MLContext final : public RefCounted<MLContext> {
+public:
+    static RefPtr<MLContext> create(std::unique_ptr<WebNN::WebNNContextImpl>&&);
+    ~MLContext();
+
+    MLDevicePreference devicePreference() const { return m_devicePreference; }
+
+    // Tensor lifecycle
+    void createTensor(MLTensorDescriptor&&, Ref<DeferredPromise>&&);
+    void writeTensor(MLTensor&, const ArrayBuffer&);
+    void readTensor(MLTensor&, Ref<DeferredPromise>&&);
+
+    // Graph execution
+    void dispatch(MLGraph&, MLNamedTensors&& inputs, MLNamedTensors&& outputs);
+
+    WebNN::WebNNContextImpl* impl() const { return m_impl.get(); }
+
+private:
+    explicit MLContext(std::unique_ptr<WebNN::WebNNContextImpl>&&);
+
+    std::unique_ptr<WebNN::WebNNContextImpl> m_impl;
+    MLDevicePreference m_devicePreference { MLDevicePreference::CPU };
+};
+
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN)
diff --git a/Source/WebCore/Modules/WebNN/MLContext.idl b/Source/WebCore/Modules/WebNN/MLContext.idl
