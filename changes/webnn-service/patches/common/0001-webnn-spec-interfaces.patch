diff --git a/Source/WebCore/Modules/WebNN/MLGraphBuilder.h b/Source/WebCore/Modules/WebNN/MLGraphBuilder.h
new file mode 100644
index 0000000000..2c3d3930e9
--- /dev/null
+++ b/Source/WebCore/Modules/WebNN/MLGraphBuilder.h
@@ -0,0 +1,85 @@
+/*
+ * https://webmachinelearning.github.io/webnn/#api-mlgraphbuilder
+ */
+
+#pragma once
+
+#if ENABLE(WEBNN)
+
+#include "Modules/WebNN/MLContext.h"
+#include "Modules/WebNN/MLOperand.h"
+#include <wtf/RefCounted.h>
+#include <wtf/RefPtr.h>
+#include <wtf/Vector.h>
+#include <wtf/HashMap.h>
+
+namespace WebCore {
+
+class DeferredPromise;
+class MLGraph;
+class ArrayBuffer;
+
+struct MLOperandDescriptor {
+    String dataType; // "float32", "float16", "int32", "uint32", "int8", "uint8"
+    Vector<unsigned> dimensions;
+};
+
+class MLGraphBuilder final : public RefCounted<MLGraphBuilder> {
+public:
+    static Ref<MLGraphBuilder> create(MLContext&);
+    ~MLGraphBuilder();
+
+    MLContext& context() const { return m_context; }
+
+    // Input and constant declaration
+    RefPtr<MLOperand> input(const String& name, MLOperandDescriptor&&);
+    RefPtr<MLOperand> constant(MLOperandDescriptor&&, const ArrayBuffer&);
+
+    // Element-wise binary
+    RefPtr<MLOperand> add(MLOperand&, MLOperand&);
+    RefPtr<MLOperand> sub(MLOperand&, MLOperand&);
+    RefPtr<MLOperand> mul(MLOperand&, MLOperand&);
+    RefPtr<MLOperand> div(MLOperand&, MLOperand&);
+
+    // Element-wise unary / activations
+    RefPtr<MLOperand> relu(MLOperand&);
+    RefPtr<MLOperand> sigmoid(MLOperand&);
+    RefPtr<MLOperand> tanh(MLOperand&);
+    RefPtr<MLOperand> softmax(MLOperand&);
+    RefPtr<MLOperand> gelu(MLOperand&);
+
+    // Linear algebra
+    RefPtr<MLOperand> matmul(MLOperand&, MLOperand&);
+    RefPtr<MLOperand> gemm(MLOperand&, MLOperand&);
+
+    // Convolution
+    RefPtr<MLOperand> conv2d(MLOperand& input, MLOperand& filter);
+
+    // Normalization
+    RefPtr<MLOperand> batchNormalization(MLOperand& input, MLOperand& mean,
+                                        MLOperand& variance);
+    RefPtr<MLOperand> layerNormalization(MLOperand& input);
+
+    // Pooling
+    RefPtr<MLOperand> averagePool2d(MLOperand&);
+    RefPtr<MLOperand> maxPool2d(MLOperand&);
+
+    // Tensor manipulation
+    RefPtr<MLOperand> reshape(MLOperand&, Vector<unsigned>&& newShape);
+    RefPtr<MLOperand> transpose(MLOperand&);
+    RefPtr<MLOperand> concat(Vector<RefPtr<MLOperand>>&&, unsigned axis);
+
+    // Graph compilation
+    void build(HashMap<String, RefPtr<MLOperand>>&& outputs,
+               Ref<DeferredPromise>&&);
+
+private:
+    explicit MLGraphBuilder(MLContext&);
+
+    MLContext& m_context;
+    Vector<RefPtr<MLOperand>> m_operands;
+};
+
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN)
diff --git a/Source/WebCore/Modules/WebNN/MLGraphBuilder.idl b/Source/WebCore/Modules/WebNN/MLGraphBuilder.idl
new file mode 100644
index 0000000000..05eaf1be98
--- /dev/null
+++ b/Source/WebCore/Modules/WebNN/MLGraphBuilder.idl
@@ -0,0 +1,56 @@
+/*
+ * https://webmachinelearning.github.io/webnn/#api-mlgraphbuilder
+ */
+
+[Conditional=WEBNN] dictionary MLOperandDescriptor {
+    required DOMString dataType;
+    required sequence<unsigned long> dimensions;
+};
+
+[
+    Conditional=WEBNN,
+    Exposed=Window,
+    SecureContext
+] interface MLGraphBuilder {
+    constructor(MLContext context);
+
+    // Inputs and constants
+    MLOperand input(DOMString name, MLOperandDescriptor descriptor);
+    MLOperand constant(MLOperandDescriptor descriptor, AllowSharedBufferSource data);
+
+    // Element-wise binary
+    MLOperand add(MLOperand a, MLOperand b);
+    MLOperand sub(MLOperand a, MLOperand b);
+    MLOperand mul(MLOperand a, MLOperand b);
+    MLOperand div(MLOperand a, MLOperand b);
+
+    // Element-wise unary / activations
+    MLOperand relu(MLOperand input);
+    MLOperand sigmoid(MLOperand input);
+    MLOperand tanh(MLOperand input);
+    MLOperand softmax(MLOperand input);
+    MLOperand gelu(MLOperand input);
+
+    // Linear algebra
+    MLOperand matmul(MLOperand a, MLOperand b);
+    MLOperand gemm(MLOperand a, MLOperand b);
+
+    // Convolution
+    MLOperand conv2d(MLOperand input, MLOperand filter);
+
+    // Normalization
+    MLOperand batchNormalization(MLOperand input, MLOperand mean, MLOperand variance);
+    MLOperand layerNormalization(MLOperand input);
+
+    // Pooling
+    MLOperand averagePool2d(MLOperand input);
+    MLOperand maxPool2d(MLOperand input);
+
+    // Tensor manipulation
+    MLOperand reshape(MLOperand input, sequence<unsigned long> newShape);
+    MLOperand transpose(MLOperand input);
+    MLOperand concat(sequence<MLOperand> inputs, unsigned long axis);
+
+    // Build
+    [NewObject] Promise<MLGraph> build(record<USVString, MLOperand> outputs);
+};
diff --git a/Source/WebCore/Modules/WebNN/MLOperand.h b/Source/WebCore/Modules/WebNN/MLOperand.h
new file mode 100644
index 0000000000..39f850acab
--- /dev/null
+++ b/Source/WebCore/Modules/WebNN/MLOperand.h
@@ -0,0 +1,50 @@
+/*
+ * https://webmachinelearning.github.io/webnn/#api-mloperand
+ */
+
+#pragma once
+
+#if ENABLE(WEBNN)
+
+#include <wtf/Ref.h>
+#include <wtf/RefCounted.h>
+#include <wtf/Vector.h>
+#include <wtf/text/WTFString.h>
+
+namespace WebCore {
+
+class MLOperand final : public RefCounted<MLOperand> {
+public:
+    enum class Kind : uint8_t {
+        Input,
+        Constant,
+        Output,
+    };
+
+    static Ref<MLOperand> createInput(const String& name, const String& dataType,
+                                       Vector<unsigned>&& dimensions);
+    static Ref<MLOperand> createConstant(const String& dataType,
+                                          Vector<unsigned>&& dimensions,
+                                          const void* data, size_t byteLength);
+    static Ref<MLOperand> createOutput(const String& dataType,
+                                        Vector<unsigned>&& dimensions);
+    ~MLOperand();
+
+    Kind kind() const { return m_kind; }
+    const String& name() const { return m_name; }
+    const String& dataType() const { return m_dataType; }
+    const Vector<unsigned>& shape() const { return m_dimensions; }
+
+private:
+    MLOperand(Kind, const String& name, const String& dataType,
+              Vector<unsigned>&&);
+
+    Kind m_kind;
+    String m_name;
+    String m_dataType;
+    Vector<unsigned> m_dimensions;
+};
+
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN)
