@@ -0,0 +1,21 @@
+/*
+ * https://webmachinelearning.github.io/webnn/#api-mlcontext
+ */
+
+[
+    Conditional=WEBNN,
+    Exposed=Window,
+    SecureContext
+] interface MLContext {
+    readonly attribute MLDevicePreference devicePreference;
+
+    [NewObject] Promise<MLTensor> createTensor(MLTensorDescriptor descriptor);
+
+    undefined writeTensor(MLTensor tensor, AllowSharedBufferSource data);
+
+    [NewObject] Promise<ArrayBuffer> readTensor(MLTensor tensor);
+
+    undefined dispatch(MLGraph graph,
+        record<USVString, MLTensor> inputs,
+        record<USVString, MLTensor> outputs);
+};
