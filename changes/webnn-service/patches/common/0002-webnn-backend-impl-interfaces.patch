diff --git a/Source/WebCore/Modules/WebNN/Implementation/WebNNContextImpl.h b/Source/WebCore/Modules/WebNN/Implementation/WebNNContextImpl.h
new file mode 100644
index 00000000000..a1b2c3d4e5f
--- /dev/null
+++ b/Source/WebCore/Modules/WebNN/Implementation/WebNNContextImpl.h
@@ -0,0 +1,50 @@
+/*
+ * Abstract backend interface for WebNN context implementations.
+ * Platform backends (ONNX Runtime, Core ML, TFLite) implement this.
+ */
+
+#pragma once
+
+#if ENABLE(WEBNN)
+
+#include "Modules/WebNN/MLContextOptions.h"
+#include "Modules/WebNN/MLTensor.h"
+#include <JavaScriptCore/ArrayBuffer.h>
+#include <wtf/FastMalloc.h>
+#include <wtf/RefPtr.h>
+#include <wtf/HashMap.h>
+#include <wtf/text/WTFString.h>
+#include <functional>
+#include <memory>
+
+namespace WebCore {
+
+class MLGraph;
+namespace WebNN {
+
+class WebNNGraphImpl;
+
+class WebNNContextImpl {
+public:
+    virtual ~WebNNContextImpl() = default;
+
+    virtual MLDevicePreference devicePreference() const = 0;
+
+    virtual RefPtr<MLTensor> createTensor(MLTensorDescriptor&&) = 0;
+    virtual void writeTensor(MLTensor&, const void* data, size_t byteLength) = 0;
+    virtual void readTensor(MLTensor&,
+                            std::function<void(RefPtr<JSC::ArrayBuffer>)>&&) = 0;
+
+    virtual void dispatch(WebNNGraphImpl&,
+                          HashMap<String, RefPtr<MLTensor>>& inputs,
+                          HashMap<String, RefPtr<MLTensor>>& outputs,
+                          std::function<void(bool)>&&) = 0;
+
+    virtual std::unique_ptr<WebNNGraphImpl> buildGraph(
+        HashMap<String, RefPtr<class MLOperand>>& outputs) = 0;
+};
+
+} // namespace WebNN
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN)
diff --git a/Source/WebCore/Modules/WebNN/Implementation/WebNNGraphImpl.h b/Source/WebCore/Modules/WebNN/Implementation/WebNNGraphImpl.h
