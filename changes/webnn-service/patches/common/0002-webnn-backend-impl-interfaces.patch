index 00000000000..b2c3d4e5f6a
--- /dev/null
+++ b/Source/WebCore/Modules/WebNN/Implementation/WebNNGraphImpl.h
@@ -0,0 +1,27 @@
+/*
+ * Abstract backend interface for WebNN compiled graph implementations.
+ */
+
+#pragma once
+
+#if ENABLE(WEBNN)
+
+#include <wtf/FastMalloc.h>
+#include <wtf/HashMap.h>
+#include <wtf/text/WTFString.h>
+
+namespace WebCore {
+namespace WebNN {
+
+class WebNNGraphImpl {
+public:
+    virtual ~WebNNGraphImpl() = default;
+
+    // Opaque handle to the compiled graph in the backend runtime.
+    virtual void* backendHandle() const { return nullptr; }
+};
+
+} // namespace WebNN
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN)
