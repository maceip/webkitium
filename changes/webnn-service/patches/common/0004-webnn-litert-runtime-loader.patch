diff --git a/Source/WebCore/Modules/WebNN/Implementation/LiteRTLoader.h b/Source/WebCore/Modules/WebNN/Implementation/LiteRTLoader.h
new file mode 100644
index 00000000000..a1b2c3d4e5f
--- /dev/null
+++ b/Source/WebCore/Modules/WebNN/Implementation/LiteRTLoader.h
@@ -0,0 +1,152 @@
+/*
+ * Runtime loader for LiteRT (TFLite) shared library.
+ *
+ * Instead of linking against libLiteRt at build time (which fails on
+ * Windows because the prebuilt ships a DLL with no import .lib), we
+ * load the library at runtime via LoadLibrary/dlopen and resolve
+ * function pointers via GetProcAddress/dlsym.
+ *
+ * This uses the TFLite C API (c_api.h), which is a stable flat C
+ * interface designed for exactly this kind of dynamic loading.
+ */
+
+#pragma once
+
+#if ENABLE(WEBNN)
+
+#include <cstddef>
+#include <cstdint>
+
+#ifdef _WIN32
+#include <windows.h>
+#else
+#include <dlfcn.h>
+#endif
+
+namespace WebCore {
+namespace WebNN {
+
+// Opaque types matching TFLite C API
+struct TfLiteModel;
+struct TfLiteInterpreterOptions;
+struct TfLiteInterpreter;
+struct TfLiteTensor;
+struct TfLiteDelegate;
+
+enum TfLiteStatus { kTfLiteOk = 0, kTfLiteError = 1, kTfLiteDelegateError = 2 };
+enum TfLiteType {
+    kTfLiteFloat32 = 1,
+    kTfLiteInt32 = 2,
+    kTfLiteUInt8 = 3,
+    kTfLiteInt64 = 4,
+    kTfLiteString = 5,
+    kTfLiteBool = 6,
+    kTfLiteInt16 = 7,
+    kTfLiteFloat16 = 10,
+    kTfLiteInt8 = 9,
+};
+
+// Function pointer typedefs for the TFLite C API
+using PFN_TfLiteModelCreate = TfLiteModel* (*)(const void* data, size_t size);
+using PFN_TfLiteModelDelete = void (*)(TfLiteModel*);
+
+using PFN_TfLiteInterpreterOptionsCreate = TfLiteInterpreterOptions* (*)();
+using PFN_TfLiteInterpreterOptionsDelete = void (*)(TfLiteInterpreterOptions*);
+using PFN_TfLiteInterpreterOptionsSetNumThreads = void (*)(TfLiteInterpreterOptions*, int32_t);
+using PFN_TfLiteInterpreterOptionsAddDelegate = void (*)(TfLiteInterpreterOptions*, TfLiteDelegate*);
+
+using PFN_TfLiteInterpreterCreate = TfLiteInterpreter* (*)(const TfLiteModel*, const TfLiteInterpreterOptions*);
+using PFN_TfLiteInterpreterDelete = void (*)(TfLiteInterpreter*);
+using PFN_TfLiteInterpreterAllocateTensors = TfLiteStatus (*)(TfLiteInterpreter*);
+using PFN_TfLiteInterpreterInvoke = TfLiteStatus (*)(TfLiteInterpreter*);
+
+using PFN_TfLiteInterpreterGetInputTensorCount = int32_t (*)(const TfLiteInterpreter*);
+using PFN_TfLiteInterpreterGetInputTensor = TfLiteTensor* (*)(const TfLiteInterpreter*, int32_t);
+using PFN_TfLiteInterpreterGetOutputTensorCount = int32_t (*)(const TfLiteInterpreter*);
+using PFN_TfLiteInterpreterGetOutputTensor = const TfLiteTensor* (*)(const TfLiteInterpreter*, int32_t);
+using PFN_TfLiteInterpreterResizeInputTensor = TfLiteStatus (*)(TfLiteInterpreter*, int32_t, const int32_t* dims, int32_t dims_size);
+
+using PFN_TfLiteTensorType = TfLiteType (*)(const TfLiteTensor*);
+using PFN_TfLiteTensorNumDims = int32_t (*)(const TfLiteTensor*);
+using PFN_TfLiteTensorDim = int32_t (*)(const TfLiteTensor*, int32_t);
+using PFN_TfLiteTensorByteSize = size_t (*)(const TfLiteTensor*);
+using PFN_TfLiteTensorData = void* (*)(const TfLiteTensor*);
+using PFN_TfLiteTensorName = const char* (*)(const TfLiteTensor*);
+using PFN_TfLiteTensorCopyFromBuffer = TfLiteStatus (*)(TfLiteTensor*, const void* data, size_t size);
+using PFN_TfLiteTensorCopyToBuffer = TfLiteStatus (*)(const TfLiteTensor*, void* data, size_t size);
+
+struct LiteRTAPI {
+    PFN_TfLiteModelCreate ModelCreate {};
+    PFN_TfLiteModelDelete ModelDelete {};
+    PFN_TfLiteInterpreterOptionsCreate InterpreterOptionsCreate {};
+    PFN_TfLiteInterpreterOptionsDelete InterpreterOptionsDelete {};
+    PFN_TfLiteInterpreterOptionsSetNumThreads InterpreterOptionsSetNumThreads {};
+    PFN_TfLiteInterpreterOptionsAddDelegate InterpreterOptionsAddDelegate {};
+    PFN_TfLiteInterpreterCreate InterpreterCreate {};
+    PFN_TfLiteInterpreterDelete InterpreterDelete {};
+    PFN_TfLiteInterpreterAllocateTensors InterpreterAllocateTensors {};
+    PFN_TfLiteInterpreterInvoke InterpreterInvoke {};
+    PFN_TfLiteInterpreterGetInputTensorCount InterpreterGetInputTensorCount {};
+    PFN_TfLiteInterpreterGetInputTensor InterpreterGetInputTensor {};
+    PFN_TfLiteInterpreterGetOutputTensorCount InterpreterGetOutputTensorCount {};
+    PFN_TfLiteInterpreterGetOutputTensor InterpreterGetOutputTensor {};
+    PFN_TfLiteInterpreterResizeInputTensor InterpreterResizeInputTensor {};
+    PFN_TfLiteTensorType TensorType {};
+    PFN_TfLiteTensorNumDims TensorNumDims {};
+    PFN_TfLiteTensorDim TensorDim {};
+    PFN_TfLiteTensorByteSize TensorByteSize {};
+    PFN_TfLiteTensorData TensorData {};
+    PFN_TfLiteTensorName TensorName {};
+    PFN_TfLiteTensorCopyFromBuffer TensorCopyFromBuffer {};
+    PFN_TfLiteTensorCopyToBuffer TensorCopyToBuffer {};
+};
+
+class LiteRTLoader {
+public:
+    static LiteRTLoader& singleton();
+
+    bool isLoaded() const { return m_loaded; }
+    const LiteRTAPI& api() const { return m_api; }
+
+private:
+    LiteRTLoader();
+    ~LiteRTLoader();
+
+    bool load();
+    void* resolve(const char* name);
+
+    bool m_loaded { false };
+    LiteRTAPI m_api {};
+
+#ifdef _WIN32
+    HMODULE m_handle { nullptr };
+#else
+    void* m_handle { nullptr };
+#endif
+};
+
+} // namespace WebNN
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN)
diff --git a/Source/WebCore/Modules/WebNN/Implementation/LiteRTLoader.cpp b/Source/WebCore/Modules/WebNN/Implementation/LiteRTLoader.cpp
new file mode 100644
index 00000000000..b2c3d4e5f6a
--- /dev/null
+++ b/Source/WebCore/Modules/WebNN/Implementation/LiteRTLoader.cpp
@@ -0,0 +1,122 @@
+#include "config.h"
+#include "LiteRTLoader.h"
+
+#if ENABLE(WEBNN)
+
+namespace WebCore {
+namespace WebNN {
+
+LiteRTLoader& LiteRTLoader::singleton()
+{
+    static LiteRTLoader instance;
+    return instance;
+}
+
+LiteRTLoader::LiteRTLoader()
+{
+    m_loaded = load();
+}
+
+LiteRTLoader::~LiteRTLoader()
+{
+    if (m_handle) {
+#ifdef _WIN32
+        FreeLibrary(m_handle);
+#else
+        dlclose(m_handle);
+#endif
+    }
+}
+
+void* LiteRTLoader::resolve(const char* name)
+{
+    if (!m_handle)
+        return nullptr;
+#ifdef _WIN32
+    return reinterpret_cast<void*>(GetProcAddress(m_handle, name));
+#else
+    return dlsym(m_handle, name);
+#endif
+}
+
+bool LiteRTLoader::load()
+{
+#ifdef _WIN32
+    const wchar_t* dllNames[] = {
+        L"libLiteRt.dll",
+        L"LiteRt.dll",
+        L"tensorflow_lite.dll",
+        L"tflite.dll",
+    };
+    for (auto* name : dllNames) {
+        m_handle = LoadLibraryExW(name, nullptr,
+            LOAD_WITH_ALTERED_SEARCH_PATH);
+        if (m_handle)
+            break;
+    }
+#elif defined(__APPLE__)
+    const char* soNames[] = {
+        "libLiteRt.dylib",
+        "libLiteRtMetalAccelerator.dylib",
+        "@rpath/libLiteRt.dylib",
+    };
+    for (auto* name : soNames) {
+        m_handle = dlopen(name, RTLD_NOW | RTLD_LOCAL);
+        if (m_handle)
+            break;
+    }
+#else
+    const char* soNames[] = {
+        "libLiteRt.so",
+        "libtensorflow-lite.so",
+        "libtflite.so",
+    };
+    for (auto* name : soNames) {
+        m_handle = dlopen(name, RTLD_NOW | RTLD_LOCAL);
+        if (m_handle)
+            break;
+    }
+#endif
+
+    if (!m_handle)
+        return false;
+
+#define LOAD_SYM(field, cname) \
+    m_api.field = reinterpret_cast<decltype(m_api.field)>(resolve(#cname)); \
+    if (!m_api.field) return false;
+
+    LOAD_SYM(ModelCreate, TfLiteModelCreate)
+    LOAD_SYM(ModelDelete, TfLiteModelDelete)
+    LOAD_SYM(InterpreterOptionsCreate, TfLiteInterpreterOptionsCreate)
+    LOAD_SYM(InterpreterOptionsDelete, TfLiteInterpreterOptionsDelete)
+    LOAD_SYM(InterpreterOptionsSetNumThreads, TfLiteInterpreterOptionsSetNumThreads)
+    LOAD_SYM(InterpreterOptionsAddDelegate, TfLiteInterpreterOptionsAddDelegate)
+    LOAD_SYM(InterpreterCreate, TfLiteInterpreterCreate)
+    LOAD_SYM(InterpreterDelete, TfLiteInterpreterDelete)
+    LOAD_SYM(InterpreterAllocateTensors, TfLiteInterpreterAllocateTensors)
+    LOAD_SYM(InterpreterInvoke, TfLiteInterpreterInvoke)
+    LOAD_SYM(InterpreterGetInputTensorCount, TfLiteInterpreterGetInputTensorCount)
+    LOAD_SYM(InterpreterGetInputTensor, TfLiteInterpreterGetInputTensor)
+    LOAD_SYM(InterpreterGetOutputTensorCount, TfLiteInterpreterGetOutputTensorCount)
+    LOAD_SYM(InterpreterGetOutputTensor, TfLiteInterpreterGetOutputTensor)
+    LOAD_SYM(InterpreterResizeInputTensor, TfLiteInterpreterResizeInputTensor)
+    LOAD_SYM(TensorType, TfLiteTensorType)
+    LOAD_SYM(TensorNumDims, TfLiteTensorNumDims)
+    LOAD_SYM(TensorDim, TfLiteTensorDim)
+    LOAD_SYM(TensorByteSize, TfLiteTensorByteSize)
+    LOAD_SYM(TensorData, TfLiteTensorData)
+    LOAD_SYM(TensorName, TfLiteTensorName)
+    LOAD_SYM(TensorCopyFromBuffer, TfLiteTensorCopyFromBuffer)
+    LOAD_SYM(TensorCopyToBuffer, TfLiteTensorCopyToBuffer)
+
+#undef LOAD_SYM
+
+    return true;
+}
+
+} // namespace WebNN
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN)
