+++ b/Source/WebCore/Modules/WebNN/MLTensor.cpp
@@ -0,0 +1,32 @@
+#include "config.h"
+#include "Modules/WebNN/MLTensor.h"
+
+#if ENABLE(WEBNN)
+
+#include <wtf/StdLibExtras.h>
+
+namespace WebCore {
+
+Ref<MLTensor> MLTensor::create(MLTensorDescriptor&& desc)
+{
+    return adoptRef(*new MLTensor(WTF::move(desc)));
+}
+
+MLTensor::MLTensor(MLTensorDescriptor&& desc)
+    : m_dataType(WTF::move(desc.dataType))
+    , m_shape(WTF::move(desc.shape))
+    , m_readable(desc.readable)
+    , m_writable(desc.writable)
+{
+}
+
+MLTensor::~MLTensor() = default;
+
+void MLTensor::destroy()
+{
+    m_destroyed = true;
+}
+
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN)
