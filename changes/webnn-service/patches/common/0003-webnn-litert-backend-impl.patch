+/*
+ * WebNN context backed by LiteRT-LM.
+ *
+ * LiteRT-LM is the unified C++ inference backend for WebNN across all
+ * platforms. It wraps LiteRT (TFLite successor) and provides:
+ * - CPU inference via XNNPACK delegate
+ * - GPU inference via platform GPU delegates (DirectX, Metal, OpenCL)
+ * - LLM orchestration via Engine/Conversation API
+ *
+ * This single implementation serves Windows, macOS, Linux, Android, and iOS.
+ */
+
+#pragma once
+
+#if ENABLE(WEBNN) && HAVE(LITERT)
+
+#include "WebNNContextImpl.h"
+#include "MLContextOptions.h"
+#include <memory>
+
+namespace WebCore {
+namespace WebNN {
+
+class LiteRTGraph;
+
+class LiteRTContext final : public WebNNContextImpl {
+public:
+    static std::unique_ptr<LiteRTContext> create(
+        const MLContextOptions& = {});
+    ~LiteRTContext() override;
+
+    MLDevicePreference devicePreference() const override { return m_device; }
+
+    RefPtr<MLTensor> createTensor(MLTensorDescriptor&&) override;
+    void writeTensor(MLTensor&, const void* data, size_t byteLength) override;
+    void readTensor(MLTensor&,
+                    std::function<void(RefPtr<ArrayBuffer>)>&&) override;
+
+    void dispatch(WebNNGraphImpl&,
+                  HashMap<String, RefPtr<MLTensor>>& inputs,
+                  HashMap<String, RefPtr<MLTensor>>& outputs,
+                  std::function<void(bool)>&&) override;
+
+    std::unique_ptr<WebNNGraphImpl> buildGraph(
+        HashMap<String, RefPtr<MLOperand>>& outputs) override;
+
+private:
+    explicit LiteRTContext(MLDevicePreference);
+    bool initialize();
+
+    MLDevicePreference m_device { MLDevicePreference::CPU };
+    bool m_initialized { false };
+
+    // LiteRT interpreter for op-level graph execution
+    // std::unique_ptr<tflite::Interpreter> m_interpreter;
+
+    // LiteRT-LM engine for model-level LLM inference
+    // std::unique_ptr<litert::lm::Engine> m_engine;
+};
+
+} // namespace WebNN
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN) && HAVE(LITERT)
