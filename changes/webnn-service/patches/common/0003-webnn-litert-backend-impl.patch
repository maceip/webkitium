@@ -0,0 +1,84 @@
+/*
+ * WebNN context backed by LiteRT (TFLite successor).
+ *
+ * The context owns a BuiltinOpResolver shared across all graphs, a GPU
+ * preference flag, and a FIFO work-queue thread that serialises
+ * dispatch() / readTensor() calls for timeline ordering.
+ */
+
+#pragma once
+
+#if ENABLE(WEBNN) && HAVE(LITERT)
+
+#include "WebNNContextImpl.h"
+#include "MLContextOptions.h"
+#include <memory>
+#include <thread>
+#include <mutex>
+#include <condition_variable>
+#include <queue>
+#include <functional>
+
+namespace tflite {
+namespace ops {
+namespace builtin {
+class BuiltinOpResolver;
+}
+}
+}
+
+namespace WebCore {
+namespace WebNN {
+
+class LiteRTGraph;
+
+class LiteRTContext final : public WebNNContextImpl {
+public:
+    static std::unique_ptr<LiteRTContext> create(
+        const MLContextOptions& = {});
+    ~LiteRTContext() override;
+
+    MLDevicePreference devicePreference() const override { return m_device; }
+    bool useGPU() const { return m_useGPU; }
+    tflite::ops::builtin::BuiltinOpResolver* opResolver() const
+    {
+        return m_opResolver.get();
+    }
+
+    RefPtr<MLTensor> createTensor(MLTensorDescriptor&&) override;
+    void writeTensor(MLTensor&, const void* data, size_t byteLength) override;
+    void readTensor(MLTensor&,
+                    std::function<void(RefPtr<ArrayBuffer>)>&&) override;
+
+    void dispatch(WebNNGraphImpl&,
+                  HashMap<String, RefPtr<MLTensor>>& inputs,
+                  HashMap<String, RefPtr<MLTensor>>& outputs,
+                  std::function<void(bool)>&&) override;
+
+    std::unique_ptr<WebNNGraphImpl> buildGraph(
+        HashMap<String, RefPtr<MLOperand>>& outputs) override;
+
+private:
+    explicit LiteRTContext(MLDevicePreference);
+    bool initialize();
+
+    void workerThreadFunc();
+    void postWork(std::function<void()>&&);
+
+    MLDevicePreference m_device { MLDevicePreference::CPU };
+    bool m_initialized { false };
+    bool m_useGPU { false };
+
+    std::unique_ptr<tflite::ops::builtin::BuiltinOpResolver> m_opResolver;
+
+    std::thread m_workerThread;
+    std::mutex m_queueMutex;
+    std::condition_variable m_queueCV;
+    std::queue<std::function<void()>> m_workQueue;
+    bool m_shutDown { false };
+};
+
+} // namespace WebNN
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN) && HAVE(LITERT)
diff --git a/Source/WebCore/Modules/WebNN/Implementation/WebNNLiteRTContext.cpp b/Source/WebCore/Modules/WebNN/Implementation/WebNNLiteRTContext.cpp
new file mode 100644
index 00000000000..b2c3d4e5f6a
--- /dev/null
+++ b/Source/WebCore/Modules/WebNN/Implementation/WebNNLiteRTContext.cpp
@@ -0,0 +1,188 @@
+/*
+ * WebNN context backed by LiteRT.
+ */
+
+#include "config.h"
+#include "WebNNLiteRTContext.h"
+
+#if ENABLE(WEBNN) && HAVE(LITERT)
+
+#include "WebNNLiteRTGraph.h"
+#include "MLTensor.h"
+#include "MLOperand.h"
+#include <tensorflow/lite/kernels/register.h>
+#include <future>
+
+namespace WebCore {
+namespace WebNN {
+
+class LiteRTTensor final : public MLTensor {
+public:
+    static Ref<LiteRTTensor> create(MLTensorDescriptor&& desc, size_t byteLength)
+    {
+        return adoptRef(*new LiteRTTensor(WTFMove(desc), byteLength));
+    }
+
+    void* data() { return m_buffer.data(); }
+    const void* data() const { return m_buffer.data(); }
+    size_t byteLength() const { return m_buffer.size(); }
+    void* backendHandle() const override
+    {
+        return const_cast<uint8_t*>(m_buffer.data());
+    }
+
+private:
+    LiteRTTensor(MLTensorDescriptor&& desc, size_t byteLength)
+        : MLTensor(WTFMove(desc))
+        , m_buffer(byteLength, 0)
+    {
+    }
+
+    Vector<uint8_t> m_buffer;
+};
+
+std::unique_ptr<LiteRTContext> LiteRTContext::create(
+    const MLContextOptions& options)
+{
+    auto context = std::unique_ptr<LiteRTContext>(
+        new LiteRTContext(options.devicePreference));
+    if (!context->initialize())
+        return nullptr;
+    return context;
+}
+
+LiteRTContext::LiteRTContext(MLDevicePreference device)
+    : m_device(device)
+{
+}
+
+LiteRTContext::~LiteRTContext()
+{
+    {
+        std::lock_guard<std::mutex> lock(m_queueMutex);
+        m_shutDown = true;
+    }
+    m_queueCV.notify_one();
+    if (m_workerThread.joinable())
+        m_workerThread.join();
+}
+
+bool LiteRTContext::initialize()
+{
+    m_opResolver = std::make_unique<tflite::ops::builtin::BuiltinOpResolver>();
+
+    if (m_device == MLDevicePreference::GPU)
+        m_useGPU = true;
+
+    m_workerThread = std::thread([this] { workerThreadFunc(); });
+
+    m_initialized = true;
+    return true;
+}
+
+void LiteRTContext::workerThreadFunc()
+{
+    while (true) {
+        std::function<void()> work;
+        {
+            std::unique_lock<std::mutex> lock(m_queueMutex);
+            m_queueCV.wait(lock, [this] {
+                return m_shutDown || !m_workQueue.empty();
+            });
+            if (m_shutDown && m_workQueue.empty())
+                return;
+            work = std::move(m_workQueue.front());
+            m_workQueue.pop();
+        }
+        work();
+    }
+}
+
+void LiteRTContext::postWork(std::function<void()>&& work)
+{
+    {
+        std::lock_guard<std::mutex> lock(m_queueMutex);
+        m_workQueue.push(std::move(work));
+    }
+    m_queueCV.notify_one();
+}
+
+static size_t bytesPerElement(const String& dataType)
+{
+    if (dataType == "float32"_s) return 4;
+    if (dataType == "float16"_s) return 2;
+    if (dataType == "int32"_s || dataType == "uint32"_s) return 4;
+    if (dataType == "int8"_s || dataType == "uint8"_s) return 1;
+    if (dataType == "int64"_s) return 8;
+    return 4;
+}
+
+static size_t tensorByteLength(const String& dataType,
+                                const Vector<unsigned>& shape)
+{
+    size_t elements = 1;
+    for (auto dim : shape)
+        elements *= dim;
+    return elements * bytesPerElement(dataType);
+}
+
+RefPtr<MLTensor> LiteRTContext::createTensor(MLTensorDescriptor&& desc)
+{
+    size_t byteLen = tensorByteLength(desc.dataType, desc.shape);
+    return LiteRTTensor::create(WTFMove(desc), byteLen);
+}
+
+void LiteRTContext::writeTensor(MLTensor& tensor, const void* data,
+                                 size_t byteLength)
+{
+    auto& lrtTensor = static_cast<LiteRTTensor&>(tensor);
+    size_t copyLen = std::min(byteLength, lrtTensor.byteLength());
+    memcpy(lrtTensor.data(), data, copyLen);
+}
+
+void LiteRTContext::readTensor(
+    MLTensor& tensor,
+    std::function<void(RefPtr<ArrayBuffer>)>&& callback)
+{
+    auto promise = std::make_shared<std::promise<RefPtr<ArrayBuffer>>>();
+    auto future = promise->get_future();
+
+    postWork([&tensor, p = std::move(promise)]() {
+        auto& lrtTensor = static_cast<LiteRTTensor&>(tensor);
+        auto buffer = ArrayBuffer::tryCreate(lrtTensor.data(),
+                                              lrtTensor.byteLength());
+        p->set_value(WTFMove(buffer));
+    });
+
+    callback(future.get());
+}
+
+void LiteRTContext::dispatch(
+    WebNNGraphImpl& graph,
+    HashMap<String, RefPtr<MLTensor>>& inputs,
+    HashMap<String, RefPtr<MLTensor>>& outputs,
+    std::function<void(bool)>&& callback)
+{
+    auto inputsCopy = inputs;
+    auto outputsCopy = outputs;
+    auto& lrtGraph = static_cast<LiteRTGraph&>(graph);
+
+    postWork([this, &lrtGraph,
+              ins = WTFMove(inputsCopy),
+              outs = WTFMove(outputsCopy),
+              cb = WTFMove(callback)]() mutable {
+        bool success = lrtGraph.run(this, ins, outs);
+        cb(success);
+    });
+}
+
+std::unique_ptr<WebNNGraphImpl> LiteRTContext::buildGraph(
+    HashMap<String, RefPtr<MLOperand>>& outputs)
+{
+    return LiteRTGraph::create(this, outputs);
+}
+
+} // namespace WebNN
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN) && HAVE(LITERT)
