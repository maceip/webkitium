@@ -0,0 +1,57 @@
+/*
+ * WebNN compiled graph backed by LiteRT via runtime-loaded C API.
+ *
+ * Uses TfLiteModelCreate / TfLiteInterpreterCreate / TfLiteInterpreterInvoke
+ * resolved at runtime through LiteRTLoader — no compile-time TFLite dependency.
+ */
+
+#pragma once
+
+#if ENABLE(WEBNN)
+
+#include "Modules/WebNN/Implementation/LiteRTLoader.h"
+#include "Modules/WebNN/Implementation/WebNNGraphImpl.h"
+#include "Modules/WebNN/MLOperand.h"
+#include "Modules/WebNN/MLTensor.h"
+#include <wtf/HashMap.h>
+#include <wtf/RefPtr.h>
+#include <wtf/text/WTFString.h>
+#include <memory>
+#include <vector>
+
+namespace WebCore {
+namespace WebNN {
+
+class LiteRTContext;
+
+class LiteRTGraph final : public WebNNGraphImpl {
+public:
+    static std::unique_ptr<LiteRTGraph> create(
+        LiteRTContext*,
+        HashMap<String, RefPtr<MLOperand>>& outputs);
+
+    ~LiteRTGraph() override;
+
+    bool run(LiteRTContext*,
+             HashMap<String, RefPtr<MLTensor>>& inputs,
+             HashMap<String, RefPtr<MLTensor>>& outputs);
+
+private:
+    LiteRTGraph();
+
+    bool buildFromOperands(LiteRTContext*,
+                           HashMap<String, RefPtr<MLOperand>>& outputs);
+
+    TfLiteModel* m_model { nullptr };
+    TfLiteInterpreter* m_interpreter { nullptr };
+    TfLiteInterpreterOptions* m_options { nullptr };
+    std::vector<uint8_t> m_modelBuffer;
+
+    Vector<String> m_inputNames;
+    Vector<String> m_outputNames;
+};
+
+} // namespace WebNN
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN)
