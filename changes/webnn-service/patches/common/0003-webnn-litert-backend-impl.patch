+/*
+ * WebNN compiled graph backed by a LiteRT interpreter.
+ *
+ * Milestone 1: lifecycle validation (build → dispatch → read).
+ * Full implementation will translate MLOperand DAG to TFLite FlatBuffer
+ * model and compile via tflite::Interpreter.
+ */
+
+#include "config.h"
+#include "WebNNLiteRTGraph.h"
+
+#if ENABLE(WEBNN) && HAVE(LITERT)
+
+#include "WebNNLiteRTContext.h"
+#include "MLOperand.h"
+#include "MLTensor.h"
+
+namespace WebCore {
+namespace WebNN {
+
+LiteRTGraph::LiteRTGraph() = default;
+LiteRTGraph::~LiteRTGraph() = default;
+
+std::unique_ptr<LiteRTGraph> LiteRTGraph::create(
+    LiteRTContext* context,
+    HashMap<String, RefPtr<MLOperand>>& outputs)
+{
+    auto graph = std::unique_ptr<LiteRTGraph>(new LiteRTGraph());
+    if (!graph->buildFromOperands(context, outputs))
+        return nullptr;
+    return graph;
+}
+
+bool LiteRTGraph::buildFromOperands(
+    LiteRTContext* context,
+    HashMap<String, RefPtr<MLOperand>>& outputs)
+{
+    if (!context)
+        return false;
+
+    for (auto& [name, operand] : outputs) {
+        if (operand)
+            m_outputNames.append(name);
+    }
+
+    // Full implementation will:
+    //
+    // 1. Walk the MLOperand DAG from outputs back to inputs.
+    //
+    // 2. Translate each MLOperand operation to a TFLite built-in op:
+    //    - add → kTfLiteBuiltinAdd
+    //    - mul → kTfLiteBuiltinMul
+    //    - relu → kTfLiteBuiltinRelu
+    //    - conv2d → kTfLiteBuiltinConv2d
+    //    - matmul → kTfLiteBuiltinBatchMatmul
+    //    - softmax → kTfLiteBuiltinSoftmax
+    //    - gelu → kTfLiteBuiltinGelu
+    //    etc. (see DESIGN.md op mapping table)
+    //
+    // 3. Serialize the graph as a TFLite FlatBuffer model in memory.
+    //
+    // 4. Create a tflite::Interpreter from the in-memory model.
+    //
+    // 5. Configure XNNPACK delegate (CPU) or GPU delegate based on
+    //    context's device preference.
+    //
+    // 6. Call m_interpreter->AllocateTensors().

+    return true;
+}
+
+bool LiteRTGraph::run(
+    LiteRTContext* context,
+    HashMap<String, RefPtr<MLTensor>>& inputs,
+    HashMap<String, RefPtr<MLTensor>>& outputs)
+{
+    if (!context)
+        return false;
+
+    // Full implementation will:
+    //
+    // 1. Bind input MLTensors to interpreter input buffers:
+    //    auto* input = m_interpreter->typed_input_tensor<float>(idx);
+    //    memcpy(input, tensor->data(), tensor->byteLength());
+    //
+    // 2. Call m_interpreter->Invoke()
+    //
+    // 3. Copy output data from interpreter to output MLTensors:
+    //    auto* output = m_interpreter->typed_output_tensor<float>(idx);
+    //    memcpy(tensor->data(), output, tensor->byteLength());
+    //
+    // For GPU delegate: tensor data may already be on device;
+    // use delegate-specific buffer sharing instead of memcpy.

+    return true;
+}
+
+} // namespace WebNN
+} // namespace WebCore
