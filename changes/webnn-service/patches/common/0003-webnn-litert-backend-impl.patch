@@ -0,0 +1,128 @@
+/*
+ * WebNN context backed by LiteRT-LM.
+ */
+
+#include "config.h"
+#include "WebNNLiteRTContext.h"
+
+#if ENABLE(WEBNN) && HAVE(LITERT)
+
+#include "WebNNLiteRTGraph.h"
+#include "MLTensor.h"
+#include "MLOperand.h"
+
+namespace WebCore {
+namespace WebNN {
+
+// Tensor subclass backed by CPU buffer (XNNPACK path)
+// GPU-backed tensors will use delegate-managed memory
+class LiteRTTensor final : public MLTensor {
+public:
+    static Ref<LiteRTTensor> create(MLTensorDescriptor&& desc, size_t byteLength)
+    {
+        return adoptRef(*new LiteRTTensor(WTFMove(desc), byteLength));
+    }
+
+    void* data() { return m_buffer.data(); }
+    const void* data() const { return m_buffer.data(); }
+    size_t byteLength() const { return m_buffer.size(); }
+
+private:
+    LiteRTTensor(MLTensorDescriptor&& desc, size_t byteLength)
+        : MLTensor(WTFMove(desc))
+        , m_buffer(byteLength, 0)
+    {
+    }
+
+    Vector<uint8_t> m_buffer;
+};
+
+std::unique_ptr<LiteRTContext> LiteRTContext::create(
+    const MLContextOptions& options)
+{
+    auto context = std::unique_ptr<LiteRTContext>(
+        new LiteRTContext(options.devicePreference));
+    if (!context->initialize())
+        return nullptr;
+    return context;
+}
+
+LiteRTContext::LiteRTContext(MLDevicePreference device)
+    : m_device(device)
+{
+}
+
+LiteRTContext::~LiteRTContext() = default;
+
+bool LiteRTContext::initialize()
+{
+    // Milestone 1: Verify LiteRT-LM library is loadable.
+    //
+    // Full initialization will:
+    // 1. Load LiteRT shared library (or verify static link)
+    // 2. Create TFLite ErrorReporter
+    // 3. Configure XNNPACK delegate for CPU backend
+    // 4. If GPU requested: load platform GPU delegate
+    //    - Windows: DirectX via ML Drift
+    //    - macOS/iOS: Metal
+    //    - Linux: OpenCL
+    //    - Android: OpenCL or NNAPI
+    // 5. For LLM mode: initialize LiteRT-LM Engine
+
+    m_initialized = true;
+    return true;
+}
+
+static size_t bytesPerElement(const String& dataType)
+{
+    if (dataType == "float32"_s)
+        return 4;
+    if (dataType == "float16"_s)
+        return 2;
+    if (dataType == "int32"_s || dataType == "uint32"_s)
+        return 4;
+    if (dataType == "int8"_s || dataType == "uint8"_s)
+        return 1;
+    if (dataType == "int64"_s)
+        return 8;
+    return 4;
+}
+
+static size_t tensorByteLength(const String& dataType,
+                                const Vector<unsigned>& shape)
+{
+    size_t elements = 1;
+    for (auto dim : shape)
+        elements *= dim;
+    return elements * bytesPerElement(dataType);
+}
+
+RefPtr<MLTensor> LiteRTContext::createTensor(MLTensorDescriptor&& desc)
+{
+    size_t byteLen = tensorByteLength(desc.dataType, desc.shape);
+    return LiteRTTensor::create(WTFMove(desc), byteLen);
+}
+
+void LiteRTContext::writeTensor(MLTensor& tensor, const void* data,
+                                 size_t byteLength)
+{
+    auto& lrtTensor = static_cast<LiteRTTensor&>(tensor);
+    size_t copyLen = std::min(byteLength, lrtTensor.byteLength());
+    memcpy(lrtTensor.data(), data, copyLen);
+}
+
+void LiteRTContext::readTensor(
+    MLTensor& tensor,
+    std::function<void(RefPtr<ArrayBuffer>)>&& callback)
+{
+    auto& lrtTensor = static_cast<LiteRTTensor&>(tensor);
+    auto buffer = ArrayBuffer::tryCreate(lrtTensor.data(),
+                                          lrtTensor.byteLength());
+    callback(WTFMove(buffer));
+}
+
+void LiteRTContext::dispatch(
+    WebNNGraphImpl& graph,
+    HashMap<String, RefPtr<MLTensor>>& inputs,
+    HashMap<String, RefPtr<MLTensor>>& outputs,
+    std::function<void(bool)>&& callback)
+{
+    auto& lrtGraph = static_cast<LiteRTGraph&>(graph);
+    bool success = lrtGraph.run(this, inputs, outputs);
+    callback(success);
+}
+
+std::unique_ptr<WebNNGraphImpl> LiteRTContext::buildGraph(
+    HashMap<String, RefPtr<MLOperand>>& outputs)
+{
+    return LiteRTGraph::create(this, outputs);
+}
+
+} // namespace WebNN
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN) && HAVE(LITERT)
