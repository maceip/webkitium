+/*
+ * WebNN compiled graph backed by a LiteRT interpreter.
+ *
+ * The graph builder translates an MLOperand DAG to a TFLite FlatBuffer model,
+ * instantiates a tflite::Interpreter with an appropriate delegate (XNNPACK for
+ * CPU, TfLiteGpuDelegateV2 for GPU), and exposes a run() method that copies
+ * tensor data in/out of the interpreter and calls Invoke().
+ */
+
+#pragma once
+
+#if ENABLE(WEBNN) && HAVE(LITERT)
+
+#include "WebNNGraphImpl.h"
+#include "MLOperand.h"
+#include "MLTensor.h"
+#include <wtf/HashMap.h>
+#include <wtf/RefPtr.h>
+#include <wtf/text/WTFString.h>
+#include <memory>
+#include <vector>
+
+namespace tflite {
+class Interpreter;
+class FlatBufferModel;
+}
+
+struct TfLiteDelegate;
+
+namespace WebCore {
+namespace WebNN {
+
+class LiteRTContext;
+
+class LiteRTGraph final : public WebNNGraphImpl {
+public:
+    static std::unique_ptr<LiteRTGraph> create(
+        LiteRTContext*,
+        HashMap<String, RefPtr<MLOperand>>& outputs);
+
+    ~LiteRTGraph() override;
+
+    bool run(LiteRTContext*,
+             HashMap<String, RefPtr<MLTensor>>& inputs,
+             HashMap<String, RefPtr<MLTensor>>& outputs);
+
+private:
+    LiteRTGraph();
+
+    bool buildFromOperands(LiteRTContext*,
+                           HashMap<String, RefPtr<MLOperand>>& outputs);
+
+    std::unique_ptr<tflite::FlatBufferModel> m_model;
+    std::unique_ptr<tflite::Interpreter> m_interpreter;
+    std::vector<uint8_t> m_modelBuffer;
+
+    enum class DelegateKind : uint8_t { None, XNNPACK, GPU };
+    DelegateKind m_delegateKind { DelegateKind::None };
+    TfLiteDelegate* m_delegate { nullptr };
+
+    HashMap<String, int> m_inputTensorIndices;
+    HashMap<String, int> m_outputTensorIndices;
+    Vector<String> m_inputNames;
+    Vector<String> m_outputNames;
+};
+
+} // namespace WebNN
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN) && HAVE(LITERT)
diff --git a/Source/WebCore/Modules/WebNN/Implementation/WebNNLiteRTGraph.cpp b/Source/WebCore/Modules/WebNN/Implementation/WebNNLiteRTGraph.cpp
new file mode 100644
index 00000000000..d4e5f6a7b8c
--- /dev/null
+++ b/Source/WebCore/Modules/WebNN/Implementation/WebNNLiteRTGraph.cpp
@@ -0,0 +1,514 @@
+/*
+ * WebNN compiled graph backed by a LiteRT interpreter.
+ *
+ * buildFromOperands() walks the MLOperand DAG in topological order,
+ * serialises it as an in-memory TFLite FlatBuffer, instantiates an
+ * Interpreter with XNNPACK (CPU) or GPU delegate, and calls
+ * AllocateTensors().
+ *
+ * run() copies input tensors into the interpreter, calls Invoke(),
+ * and copies results back to output MLTensors.
+ */
+
+#include "config.h"
+#include "WebNNLiteRTGraph.h"
+
+#if ENABLE(WEBNN) && HAVE(LITERT)
+
+#include "WebNNLiteRTContext.h"
+#include "MLOperand.h"
+#include "MLTensor.h"
+
+#include <tensorflow/lite/interpreter.h>
+#include <tensorflow/lite/interpreter_builder.h>
+#include <tensorflow/lite/model_builder.h>
+#include <tensorflow/lite/kernels/register.h>
+#include <tensorflow/lite/delegates/xnnpack/xnnpack_delegate.h>
+#include <tensorflow/lite/schema/schema_generated.h>
+#include <tensorflow/lite/c/common.h>
+
+#if HAVE(LITERT_GPU_DELEGATE)
+#include <tensorflow/lite/delegates/gpu/delegate.h>
+#endif
+
+#include <flatbuffers/flatbuffers.h>
+#include <wtf/HashSet.h>
+#include <wtf/text/CString.h>
+
+namespace WebCore {
+namespace WebNN {
+
+namespace {
+
+tflite::TensorType mapDataType(const String& dataType)
+{
+    if (dataType == "float32"_s) return tflite::TensorType_FLOAT32;
+    if (dataType == "float16"_s) return tflite::TensorType_FLOAT16;
+    if (dataType == "int32"_s)   return tflite::TensorType_INT32;
+    if (dataType == "int8"_s)    return tflite::TensorType_INT8;
+    if (dataType == "uint8"_s)   return tflite::TensorType_UINT8;
+    if (dataType == "int64"_s)   return tflite::TensorType_INT64;
+    return tflite::TensorType_FLOAT32;
+}
+
+tflite::BuiltinOperator mapOperationType(const String& opType)
+{
+    if (opType == "add"_s)           return tflite::BuiltinOperator_ADD;
+    if (opType == "sub"_s)           return tflite::BuiltinOperator_SUB;
+    if (opType == "mul"_s)           return tflite::BuiltinOperator_MUL;
+    if (opType == "div"_s)           return tflite::BuiltinOperator_DIV;
+    if (opType == "relu"_s)          return tflite::BuiltinOperator_RELU;
+    if (opType == "sigmoid"_s)       return tflite::BuiltinOperator_LOGISTIC;
+    if (opType == "tanh"_s)          return tflite::BuiltinOperator_TANH;
+    if (opType == "softmax"_s)       return tflite::BuiltinOperator_SOFTMAX;
+    if (opType == "matmul"_s)        return tflite::BuiltinOperator_BATCH_MATMUL;
+    if (opType == "reshape"_s)       return tflite::BuiltinOperator_RESHAPE;
+    if (opType == "transpose"_s)     return tflite::BuiltinOperator_TRANSPOSE;
+    if (opType == "concat"_s)        return tflite::BuiltinOperator_CONCATENATION;
+    if (opType == "averagePool2d"_s) return tflite::BuiltinOperator_AVERAGE_POOL_2D;
+    if (opType == "maxPool2d"_s)     return tflite::BuiltinOperator_MAX_POOL_2D;
+    if (opType == "conv2d"_s)        return tflite::BuiltinOperator_CONV_2D;
+    if (opType == "gelu"_s)          return tflite::BuiltinOperator_GELU;
+    return tflite::BuiltinOperator_CUSTOM;
+}
+
+void collectOperandsTopological(MLOperand* operand,
+                                 HashSet<MLOperand*>& visited,
+                                 Vector<RefPtr<MLOperand>>& sorted)
+{
+    if (!operand || visited.contains(operand))
+        return;
+    visited.add(operand);
+
+    if (operand->kind() == MLOperand::Kind::Output) {
+        for (auto& input : operand->inputOperands())
+            collectOperandsTopological(input.get(), visited, sorted);
+    }
+    sorted.append(operand);
+}
+
+struct OperatorRecord {
+    tflite::BuiltinOperator builtinOp;
+    Vector<int32_t> inputIndices;
+    int32_t outputIndex;
+    const MLOperand* outputOperand;
+};
+
+void createBuiltinOptions(flatbuffers::FlatBufferBuilder& fbb,
+                           tflite::BuiltinOperator op,
+                           const MLOperand* operand,
+                           tflite::BuiltinOptions& outType,
+                           flatbuffers::Offset<void>& outOffset)
+{
+    using namespace tflite;
+    switch (op) {
+    case BuiltinOperator_ADD:
+        outType = BuiltinOptions_AddOptions;
+        outOffset = CreateAddOptions(fbb,
+            ActivationFunctionType_NONE).Union();
+        return;
+    case BuiltinOperator_SUB:
+        outType = BuiltinOptions_SubOptions;
+        outOffset = CreateSubOptions(fbb,
+            ActivationFunctionType_NONE).Union();
+        return;
+    case BuiltinOperator_MUL:
+        outType = BuiltinOptions_MulOptions;
+        outOffset = CreateMulOptions(fbb,
+            ActivationFunctionType_NONE).Union();
+        return;
+    case BuiltinOperator_DIV:
+        outType = BuiltinOptions_DivOptions;
+        outOffset = CreateDivOptions(fbb,
+            ActivationFunctionType_NONE).Union();
+        return;
+    case BuiltinOperator_SOFTMAX:
+        outType = BuiltinOptions_SoftmaxOptions;
+        outOffset = CreateSoftmaxOptions(fbb, 1.0f).Union();
+        return;
+    case BuiltinOperator_RESHAPE: {
+        Vector<int32_t> dims;
+        for (auto d : operand->shape())
+            dims.append(static_cast<int32_t>(d));
+        auto shapeVec = fbb.CreateVector(
+            dims.data(), dims.size());
+        outType = BuiltinOptions_ReshapeOptions;
+        outOffset = CreateReshapeOptions(fbb, shapeVec).Union();
+        return;
+    }
+    case BuiltinOperator_CONCATENATION:
+        outType = BuiltinOptions_ConcatenationOptions;
+        outOffset = CreateConcatenationOptions(
+            fbb, 0, ActivationFunctionType_NONE).Union();
+        return;
+    case BuiltinOperator_CONV_2D:
+        outType = BuiltinOptions_Conv2DOptions;
+        outOffset = CreateConv2DOptions(
+            fbb, Padding_SAME, 1, 1,
+            ActivationFunctionType_NONE, 1, 1).Union();
+        return;
+    case BuiltinOperator_AVERAGE_POOL_2D:
+    case BuiltinOperator_MAX_POOL_2D:
+        outType = BuiltinOptions_Pool2DOptions;
+        outOffset = CreatePool2DOptions(
+            fbb, Padding_SAME, 1, 1, 1, 1,
+            ActivationFunctionType_NONE).Union();
+        return;
+    case BuiltinOperator_BATCH_MATMUL:
+        outType = BuiltinOptions_BatchMatMulOptions;
+        outOffset = CreateBatchMatMulOptions(
+            fbb, false, false).Union();
+        return;
+    default:
+        outType = BuiltinOptions_NONE;
+        outOffset = 0;
+        return;
+    }
+}
+
+size_t bytesPerElement(const String& dataType)
+{
+    if (dataType == "float32"_s) return 4;
+    if (dataType == "float16"_s) return 2;
+    if (dataType == "int32"_s || dataType == "uint32"_s) return 4;
+    if (dataType == "int8"_s || dataType == "uint8"_s) return 1;
+    if (dataType == "int64"_s) return 8;
+    return 4;
+}
+
+size_t computeTensorByteLength(const String& dataType,
+                                const Vector<unsigned>& shape)
+{
+    size_t elements = 1;
+    for (auto dim : shape)
+        elements *= dim;
+    return elements * bytesPerElement(dataType);
+}
+
+} // anonymous namespace
+
+LiteRTGraph::LiteRTGraph() = default;
+
+LiteRTGraph::~LiteRTGraph()
+{
+    m_interpreter.reset();
+    m_model.reset();
+
+    if (m_delegate) {
+        switch (m_delegateKind) {
+        case DelegateKind::XNNPACK:
+            TfLiteXNNPackDelegateDelete(m_delegate);
+            break;
+        case DelegateKind::GPU:
+#if HAVE(LITERT_GPU_DELEGATE)
+            TfLiteGpuDelegateV2Delete(m_delegate);
+#endif
+            break;
+        case DelegateKind::None:
+            break;
+        }
+    }
+}
+
+std::unique_ptr<LiteRTGraph> LiteRTGraph::create(
+    LiteRTContext* context,
+    HashMap<String, RefPtr<MLOperand>>& outputs)
+{
+    auto graph = std::unique_ptr<LiteRTGraph>(new LiteRTGraph());
+    if (!graph->buildFromOperands(context, outputs))
+        return nullptr;
+    return graph;
+}
+
+bool LiteRTGraph::buildFromOperands(
+    LiteRTContext* context,
+    HashMap<String, RefPtr<MLOperand>>& outputs)
+{
+    if (!context || !context->opResolver())
+        return false;
+
+    // Step 1: walk the MLOperand DAG from outputs back to inputs,
+    // producing a topologically-sorted list (inputs first).
+    HashSet<MLOperand*> visited;
+    Vector<RefPtr<MLOperand>> sorted;
+    for (auto& [name, operand] : outputs) {
+        if (operand)
+            collectOperandsTopological(operand.get(), visited, sorted);
+    }
+
+    // Step 2: assign a unique FlatBuffer tensor index to every operand.
+    HashMap<MLOperand*, int32_t> tensorIndexMap;
+    int32_t nextIdx = 0;
+    for (auto& operand : sorted)
+        tensorIndexMap.set(operand.get(), nextIdx++);
+
+    // Step 3: classify operands into graph inputs, constants, and
+    // operation outputs; build OperatorRecords for each op.
+    Vector<int32_t> graphInputIndices;
+    Vector<int32_t> graphOutputIndices;
+    Vector<OperatorRecord> opRecords;
+
+    for (auto& operand : sorted) {
+        switch (operand->kind()) {
+        case MLOperand::Kind::Input:
+            m_inputNames.append(operand->name());
+            graphInputIndices.append(
+                tensorIndexMap.get(operand.get()));
+            break;
+        case MLOperand::Kind::Constant:
+            break;
+        case MLOperand::Kind::Output: {
+            auto builtinOp = mapOperationType(
+                operand->operationType());
+            if (builtinOp == tflite::BuiltinOperator_CUSTOM)
+                return false;
+
+            OperatorRecord rec;
+            rec.builtinOp = builtinOp;
+            rec.outputIndex = tensorIndexMap.get(operand.get());
+            rec.outputOperand = operand.get();
+            for (auto& input : operand->inputOperands()) {
+                auto it = tensorIndexMap.find(input.get());
+                if (it == tensorIndexMap.end())
+                    return false;
+                rec.inputIndices.append(it->value);
+            }
+            opRecords.append(WTFMove(rec));
+            break;
+        }
+        }
+    }
+
+    for (auto& [name, operand] : outputs) {
+        m_outputNames.append(name);
+        graphOutputIndices.append(
+            tensorIndexMap.get(operand.get()));
+    }
+
+    // Step 4: serialise the graph as a TFLite FlatBuffer in memory.
+    flatbuffers::FlatBufferBuilder fbb(4096);
+
+    // Buffer 0 is always empty per TFLite convention.
+    std::vector<flatbuffers::Offset<tflite::Buffer>> buffers;
+    buffers.push_back(tflite::CreateBuffer(fbb));
+
+    // 4a. Tensors
+    std::vector<flatbuffers::Offset<tflite::Tensor>> tensors;
+    for (auto& operand : sorted) {
+        Vector<int32_t> shape;
+        for (auto dim : operand->shape())
+            shape.append(static_cast<int32_t>(dim));
+        auto shapeFB = fbb.CreateVector(
+            shape.data(), shape.size());
+
+        CString nameUTF8 = operand->name().utf8();
+        auto nameFB = fbb.CreateString(
+            nameUTF8.data(), nameUTF8.length());
+
+        uint32_t bufferIdx = 0;
+        if (operand->kind() == MLOperand::Kind::Constant
+            && operand->constantData()) {
+            auto dataFB = fbb.CreateVector(
+                static_cast<const uint8_t*>(
+                    operand->constantData()),
+                operand->constantByteLength());
+            buffers.push_back(
+                tflite::CreateBuffer(fbb, dataFB));
+            bufferIdx = static_cast<uint32_t>(
+                buffers.size() - 1);
+        }
+
+        tensors.push_back(tflite::CreateTensor(
+            fbb, shapeFB,
+            mapDataType(operand->dataType()),
+            bufferIdx, nameFB));
+    }
+
+    // 4b. Operator codes (deduplicated)
+    HashMap<int, uint32_t> opCodeIndexMap;
+    std::vector<flatbuffers::Offset<tflite::OperatorCode>>
+        opCodes;
+    for (auto& rec : opRecords) {
+        int key = static_cast<int>(rec.builtinOp);
+        if (!opCodeIndexMap.contains(key)) {
+            opCodeIndexMap.set(key,
+                static_cast<uint32_t>(opCodes.size()));
+            opCodes.push_back(tflite::CreateOperatorCode(
+                fbb, 0, 0, 1, rec.builtinOp));
+        }
+    }
+
+    // 4c. Operators
+    std::vector<flatbuffers::Offset<tflite::Operator>> operators;
+    for (auto& rec : opRecords) {
+        uint32_t ocIdx = opCodeIndexMap.get(
+            static_cast<int>(rec.builtinOp));
+        auto inFB = fbb.CreateVector(
+            rec.inputIndices.data(),
+            rec.inputIndices.size());
+        std::vector<int32_t> outVec = { rec.outputIndex };
+        auto outFB = fbb.CreateVector(outVec);
+
+        tflite::BuiltinOptions optType;
+        flatbuffers::Offset<void> optOff;
+        createBuiltinOptions(fbb, rec.builtinOp,
+            rec.outputOperand, optType, optOff);
+
+        operators.push_back(tflite::CreateOperator(
+            fbb, ocIdx, inFB, outFB, optType, optOff));
+    }
+
+    // 4d. SubGraph
+    auto tensorsFB  = fbb.CreateVector(tensors);
+    auto gInputsFB  = fbb.CreateVector(
+        graphInputIndices.data(),
+        graphInputIndices.size());
+    auto gOutputsFB = fbb.CreateVector(
+        graphOutputIndices.data(),
+        graphOutputIndices.size());
+    auto opersFB    = fbb.CreateVector(operators);
+    auto gName      = fbb.CreateString("main");
+    auto subGraph   = tflite::CreateSubGraph(
+        fbb, tensorsFB, gInputsFB, gOutputsFB,
+        opersFB, gName);
+
+    // 4e. Model
+    auto opCodesFB = fbb.CreateVector(opCodes);
+    std::vector<flatbuffers::Offset<tflite::SubGraph>>
+        subs = { subGraph };
+    auto subsFB = fbb.CreateVector(subs);
+    auto desc   = fbb.CreateString("WebNN LiteRT graph");
+    auto bufsFB = fbb.CreateVector(buffers);
+    auto model  = tflite::CreateModel(
+        fbb, TFLITE_SCHEMA_VERSION,
+        opCodesFB, subsFB, desc, bufsFB);
+    fbb.Finish(model);
+
+    // Step 5: build interpreter from the in-memory FlatBuffer.
+    m_modelBuffer.assign(
+        fbb.GetBufferPointer(),
+        fbb.GetBufferPointer() + fbb.GetSize());
+
+    m_model = tflite::FlatBufferModel::BuildFromBuffer(
+        reinterpret_cast<const char*>(m_modelBuffer.data()),
+        m_modelBuffer.size());
+    if (!m_model)
+        return false;
+
+    tflite::InterpreterBuilder builder(
+        *m_model, *context->opResolver());
+    if (builder(&m_interpreter) != kTfLiteOk
+        || !m_interpreter)
+        return false;
+
+    // Step 6: attach delegate — try GPU first if requested,
+    // fall back silently to XNNPACK on failure.
+#if HAVE(LITERT_GPU_DELEGATE)
+    if (context->useGPU()) {
+        TfLiteGpuDelegateOptionsV2 gpuOpts =
+            TfLiteGpuDelegateOptionsV2Default();
+        TfLiteDelegate* gpu =
+            TfLiteGpuDelegateV2Create(&gpuOpts);
+        if (gpu) {
+            if (m_interpreter->ModifyGraphWithDelegate(gpu)
+                == kTfLiteOk) {
+                m_delegate = gpu;
+                m_delegateKind = DelegateKind::GPU;
+            } else {
+                TfLiteGpuDelegateV2Delete(gpu);
+            }
+        }
+    }
+#endif
+
+    if (!m_delegate) {
+        TfLiteXNNPackDelegateOptions xnnOpts =
+            TfLiteXNNPackDelegateOptionsDefault();
+        m_delegate = TfLiteXNNPackDelegateCreate(&xnnOpts);
+        if (m_delegate) {
+            m_interpreter->ModifyGraphWithDelegate(m_delegate);
+            m_delegateKind = DelegateKind::XNNPACK;
+        }
+    }
+
+    if (m_interpreter->AllocateTensors() != kTfLiteOk)
+        return false;
+
+    // Step 7: build name-to-interpreter-tensor-index maps so
+    // run() can locate tensors by binding name in O(1).
+    const auto& interpInputs = m_interpreter->inputs();
+    for (size_t i = 0; i < m_inputNames.size()
+                     && i < interpInputs.size(); ++i)
+        m_inputTensorIndices.set(
+            m_inputNames[i], interpInputs[i]);
+
+    const auto& interpOutputs = m_interpreter->outputs();
+    for (size_t i = 0; i < m_outputNames.size()
+                     && i < interpOutputs.size(); ++i)
+        m_outputTensorIndices.set(
+            m_outputNames[i], interpOutputs[i]);
+
+    return true;
+}
+
+bool LiteRTGraph::run(
+    LiteRTContext*,
+    HashMap<String, RefPtr<MLTensor>>& inputs,
+    HashMap<String, RefPtr<MLTensor>>& outputs)
+{
+    if (!m_interpreter)
+        return false;
+
+    // Copy input MLTensor data into interpreter input buffers.
+    for (auto& [name, tensor] : inputs) {
+        auto it = m_inputTensorIndices.find(name);
+        if (it == m_inputTensorIndices.end())
+            return false;
+
+        TfLiteTensor* tfl = m_interpreter->tensor(it->value);
+        if (!tfl || !tfl->data.raw)
+            return false;
+
+        void* src = tensor->backendHandle();
+        if (!src)
+            return false;
+
+        size_t srcBytes = computeTensorByteLength(
+            tensor->dataType(), tensor->shape());
+        size_t copyLen = std::min(
+            srcBytes, static_cast<size_t>(tfl->bytes));
+        memcpy(tfl->data.raw, src, copyLen);
+    }
+
+    if (m_interpreter->Invoke() != kTfLiteOk)
+        return false;
+
+    // Copy interpreter output buffers into output MLTensors.
+    for (auto& [name, tensor] : outputs) {
+        auto it = m_outputTensorIndices.find(name);
+        if (it == m_outputTensorIndices.end())
+            return false;
+
+        const TfLiteTensor* tfl =
+            m_interpreter->tensor(it->value);
+        if (!tfl || !tfl->data.raw)
+            return false;
+
+        void* dst = tensor->backendHandle();
+        if (!dst)
+            return false;
+
+        size_t dstBytes = computeTensorByteLength(
+            tensor->dataType(), tensor->shape());
+        size_t copyLen = std::min(
+            dstBytes, static_cast<size_t>(tfl->bytes));
+        memcpy(dst, tfl->data.raw, copyLen);
+    }
+
+    return true;
+}
