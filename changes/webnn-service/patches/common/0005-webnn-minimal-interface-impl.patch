diff --git a/Source/WebCore/Modules/WebNN/MLOperand.cpp b/Source/WebCore/Modules/WebNN/MLOperand.cpp
new file mode 100644
index 0000000000..3b4c5d6e7f
--- /dev/null
+++ b/Source/WebCore/Modules/WebNN/MLOperand.cpp
@@ -0,0 +1,40 @@
+#include "config.h"
+#include "Modules/WebNN/MLOperand.h"
+
+#if ENABLE(WEBNN)
+
+#include <wtf/StdLibExtras.h>
+
+namespace WebCore {
+
+Ref<MLOperand> MLOperand::createInput(const String& name, const String& dataType, Vector<unsigned>&& dimensions)
+{
+    return adoptRef(*new MLOperand(Kind::Input, name, dataType, WTF::move(dimensions)));
+}
+
+Ref<MLOperand> MLOperand::createConstant(const String& dataType, Vector<unsigned>&& dimensions, const void* data, size_t byteLength)
+{
+    auto operand = adoptRef(*new MLOperand(Kind::Constant, emptyString(), dataType, WTF::move(dimensions)));
+    operand->m_constantData = data;
+    operand->m_constantByteLength = byteLength;
+    return operand;
+}
+
+Ref<MLOperand> MLOperand::createOutput(const String& dataType, Vector<unsigned>&& dimensions)
+{
+    return adoptRef(*new MLOperand(Kind::Output, emptyString(), dataType, WTF::move(dimensions)));
+}
+
+MLOperand::MLOperand(Kind kind, const String& name, const String& dataType, Vector<unsigned>&& dimensions)
+    : m_kind(kind)
+    , m_name(name)
+    , m_dataType(dataType)
+    , m_dimensions(WTF::move(dimensions))
+{
+}
+
+MLOperand::~MLOperand() = default;
+
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN)
