diff --git a/Source/WebCore/Modules/WebNN/MLContext.cpp b/Source/WebCore/Modules/WebNN/MLContext.cpp
new file mode 100644
index 0000000000..1f2e3d4c5b
--- /dev/null
+++ b/Source/WebCore/Modules/WebNN/MLContext.cpp
@@ -0,0 +1,71 @@
+#include "config.h"
+#include "Modules/WebNN/MLContext.h"
+
+#if ENABLE(WEBNN)
+
+#include "Modules/WebNN/Implementation/WebNNContextImpl.h"
+#include "Modules/WebNN/MLGraph.h"
+#include "Modules/WebNN/MLTensor.h"
+#include "bindings/js/JSDOMPromiseDeferred.h"
+#include <JavaScriptCore/ArrayBuffer.h>
+#include <wtf/StdLibExtras.h>
+
+namespace WebCore {
+
+RefPtr<MLContext> MLContext::create(std::unique_ptr<WebNN::WebNNContextImpl>&& impl)
+{
+    if (!impl)
+        return nullptr;
+    return adoptRef(*new MLContext(WTF::move(impl)));
+}
+
+MLContext::MLContext(std::unique_ptr<WebNN::WebNNContextImpl>&& impl)
+    : m_impl(WTF::move(impl))
+{
+    if (m_impl)
+        m_devicePreference = m_impl->devicePreference();
+}
+
+MLContext::~MLContext() = default;
+
+void MLContext::createTensor(MLTensorDescriptor&& descriptor, Ref<DeferredPromise>&& promise)
+{
+    if (!m_impl) {
+        promise->reject(Exception { ExceptionCode::InvalidStateError, "WebNN context is not initialized"_s });
+        return;
+    }
+
+    auto tensor = m_impl->createTensor(WTF::move(descriptor));
+    if (!tensor) {
+        promise->reject(Exception { ExceptionCode::OperationError, "WebNN tensor creation failed"_s });
+        return;
+    }
+
+    promise->resolve();
+}
+
+void MLContext::writeTensor(MLTensor& tensor, const ArrayBuffer& buffer)
+{
+    if (!m_impl)
+        return;
+    m_impl->writeTensor(tensor, buffer.data(), buffer.byteLength());
+}
+
+void MLContext::readTensor(MLTensor& tensor, Ref<DeferredPromise>&& promise)
+{
+    if (!m_impl) {
+        promise->reject(Exception { ExceptionCode::InvalidStateError, "WebNN context is not initialized"_s });
+        return;
+    }
+    m_impl->readTensor(tensor, [promise = WTF::move(promise)](RefPtr<JSC::ArrayBuffer>) mutable {
+        promise->resolve();
+    });
+}
+
+void MLContext::dispatch(MLGraph&, MLNamedTensors&&, MLNamedTensors&&)
+{
+}
+
+} // namespace WebCore
+
+#endif // ENABLE(WEBNN)
