 #include <wtf/TZoneMallocInlines.h>
 
 namespace WebCore {
 
 WTF_MAKE_TZONE_ALLOCATED_IMPL(GPUCanvasContextWin);
 
+static HWND resolveHostHWND(CanvasBase& canvasBase)
+{
+    // Walk canvas -> Document -> Page -> Chrome to find the native host
+    // window. Returns nullptr for OffscreenCanvas in a Worker (no Page),
+    // in which case the canvas stays in a pre-bound error state and
+    // getCurrentTexture() reports InvalidStateError until a host binds it.
+    RefPtr scriptCtx = canvasBase.scriptExecutionContext();
+    auto* document = dynamicDowncast<Document>(scriptCtx.get());
+    if (!document)
+        return nullptr;
+    RefPtr page = document->page();
+    if (!page)
+        return nullptr;
+    return static_cast<HWND>(page->chrome().platformPageClient());
+}
+
+static void resolveCanvasPixelSize(CanvasBase& canvasBase, uint32_t& width, uint32_t& height)
+{
+    auto size = canvasBase.size();
+    width  = std::max<uint32_t>(1, static_cast<uint32_t>(size.width()));
+    height = std::max<uint32_t>(1, static_cast<uint32_t>(size.height()));
+}
+
 std::unique_ptr<GPUCanvasContextWin> GPUCanvasContextWin::create(CanvasBase& canvas, GPU& gpu, Document*)
 {
     auto presentationContext = gpu.createPresentationContextForHWND(nullptr, nullptr);
@@ -28,6 +53,12 @@ std::unique_ptr<GPUCanvasContextWin> GPUCanvasContextWin::create(CanvasBase& can
         return nullptr;
     auto context = std::unique_ptr<GPUCanvasContextWin>(new GPUCanvasContextWin(canvas, WTF::move(presentationContext)));
     context->m_gpu = &gpu;
+
+    if (HWND hwnd = resolveHostHWND(canvas)) {
+        uint32_t w = 0, h = 0;
+        resolveCanvasPixelSize(canvas, w, h);
+        context->setHostHWND(hwnd, w, h);
+    }
     return context;
 }
 
