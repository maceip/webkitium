+Ref<SupportedLimits> supportedLimitsFromDawnLimits(const WGPULimits& limits)
+{
+    // WebKit still exposes maxInterStageShaderComponents; Dawn reports variables only. Approximate conservatively.
+    uint32_t maxInterStageShaderComponents = std::min(60u, limits.maxInterStageShaderVariables * 4);
+
+    uint32_t perStageBuffers = limits.maxStorageBuffersPerShaderStage;
+    uint32_t perStageTextures = limits.maxStorageTexturesPerShaderStage;
+
+    return SupportedLimits::create(
+        limits.maxTextureDimension1D,
+        limits.maxTextureDimension2D,
+        limits.maxTextureDimension3D,
+        limits.maxTextureArrayLayers,
+        limits.maxBindGroups,
+        limits.maxBindGroupsPlusVertexBuffers,
+        limits.maxBindingsPerBindGroup,
+        limits.maxDynamicUniformBuffersPerPipelineLayout,
+        limits.maxDynamicStorageBuffersPerPipelineLayout,
+        limits.maxSampledTexturesPerShaderStage,
+        limits.maxSamplersPerShaderStage,
+        limits.maxStorageBuffersPerShaderStage,
+        limits.maxStorageTexturesPerShaderStage,
+        limits.maxUniformBuffersPerShaderStage,
+        limits.maxUniformBufferBindingSize,
+        limits.maxStorageBufferBindingSize,
+        limits.minUniformBufferOffsetAlignment,
+        limits.minStorageBufferOffsetAlignment,
+        limits.maxVertexBuffers,
+        limits.maxBufferSize,
+        limits.maxVertexAttributes,
+        limits.maxVertexBufferArrayStride,
+        maxInterStageShaderComponents,
+        limits.maxInterStageShaderVariables,
+        limits.maxColorAttachments,
+        limits.maxColorAttachmentBytesPerSample,
+        limits.maxComputeWorkgroupStorageSize,
+        limits.maxComputeInvocationsPerWorkgroup,
+        limits.maxComputeWorkgroupSizeX,
+        limits.maxComputeWorkgroupSizeY,
+        limits.maxComputeWorkgroupSizeZ,
+        limits.maxComputeWorkgroupsPerDimension,
+        perStageBuffers,
+        perStageTextures,
+        perStageBuffers,
+        perStageTextures);
+}
+
+Ref<SupportedLimits> supportedLimitsFromAdapter(WGPUAdapter adapter)
+{
+    WGPULimits limits { };
+    auto status = wgpuAdapterGetLimits(adapter, &limits);
+    ASSERT_UNUSED(status, status == WGPUStatus_Success);
+    return supportedLimitsFromDawnLimits(limits);
+}
+
+Ref<SupportedFeatures> supportedFeaturesFromAdapter(WGPUAdapter adapter)
+{
+    WGPUSupportedFeatures probe { };
+    wgpuAdapterGetFeatures(adapter, &probe);
+
+    Vector<WGPUFeatureName> backing;
+    backing.resize(probe.featureCount);
+    WGPUSupportedFeatures resolved {
+        .featureCount = probe.featureCount,
+        .features = backing.mutableSpan().data(),
+    };
+    wgpuAdapterGetFeatures(adapter, &resolved);
+
+    Vector<String> names;
+    names.reserveInitialCapacity(resolved.featureCount);
+    for (size_t i = 0; i < resolved.featureCount; ++i)
+        names.append(dawnFeatureName(resolved.features[i]));
+
+    return SupportedFeatures::create(WTF::move(names));
+}
+
+Ref<SupportedLimits> supportedLimitsFromDevice(WGPUDevice device)
+{
+    WGPULimits limits { };
+    auto status = wgpuDeviceGetLimits(device, &limits);
+    ASSERT_UNUSED(status, status == WGPUStatus_Success);
+    return supportedLimitsFromDawnLimits(limits);
+}
+
+Ref<SupportedFeatures> supportedFeaturesFromDevice(WGPUDevice device)
+{
+    WGPUSupportedFeatures probe { };
+    wgpuDeviceGetFeatures(device, &probe);
+
+    Vector<WGPUFeatureName> backing;
+    backing.resize(probe.featureCount);
+    WGPUSupportedFeatures resolved {
+        .featureCount = probe.featureCount,
+        .features = backing.mutableSpan().data(),
+    };
+    wgpuDeviceGetFeatures(device, &resolved);
+
+    Vector<String> names;
+    names.reserveInitialCapacity(resolved.featureCount);
+    for (size_t i = 0; i < resolved.featureCount; ++i)
+        names.append(dawnFeatureName(resolved.features[i]));
+
+    return SupportedFeatures::create(WTF::move(names));
+}
+
+void waitForFuture(WGPUInstance instance, WGPUFuture future)
+{
+    // AllowProcessEvents callbacks fire during wgpuInstanceProcessEvents.
+    // A blocking wgpuInstanceWaitAny with non-zero timeout would require
+    // instanceDesc.features.timedWaitAnyEnable = true (we don't set it)
+    // and otherwise returns ErrorTimeout after ~15s without firing the
+    // callback. Use ProcessEvents to drive the callback and a 0-timeout
+    // WaitAny to poll waitInfo.completed (the 0-timeout poll path does
+    // not need timedWaitAnyEnable). Matches the standalone harness.
+    WGPUFutureWaitInfo waitInfo { };
+    waitInfo.future = future;
+    waitInfo.completed = false;
+    auto deadline = MonotonicTime::now() + 30_s;
+    while (!waitInfo.completed) {
+        wgpuInstanceProcessEvents(instance);
+        wgpuInstanceWaitAny(instance, 1, &waitInfo, 0);
+        if (MonotonicTime::now() > deadline)
+            break;
+    }
+}
+
+WGPUShaderModule deviceCreateShaderModule(WGPUDevice device, const String& wgsl, const String& label)
+{
+    auto codeUtf8 = wgsl.utf8();
+    WGPUShaderSourceWGSL wgslSource { };
+    wgslSource.chain.next = nullptr;
+    wgslSource.chain.sType = WGPUSType_ShaderSourceWGSL;
+    wgslSource.code = toDawnStringView(codeUtf8);
+
+    WGPUShaderModuleDescriptor moduleDescriptor { };
+    moduleDescriptor.nextInChain = &wgslSource.chain;
+    moduleDescriptor.label = toDawnStringView(label);
+
+    return wgpuDeviceCreateShaderModule(device, &moduleDescriptor);
+}
