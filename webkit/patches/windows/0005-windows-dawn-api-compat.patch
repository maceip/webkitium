+
+#include "config.h"
+
+#if PLATFORM(WIN)
+
+#include "WebGPUDawnCompat.h"
+
+#include <algorithm>
+#include <cstring>
+#include <span>
+#include <wtf/MonotonicTime.h>
+
+namespace WebCore::WebGPU::DawnCompat {
+
+WGPUStringView toDawnStringView(const char* utf8NullTerminated)
+{
+    if (!utf8NullTerminated || !*utf8NullTerminated)
+        return { nullptr, 0 };
+    return { utf8NullTerminated, WGPU_STRLEN };
+}
+
+WGPUStringView toDawnStringView(const CString& utf8)
+{
+    if (utf8.isEmpty())
+        return { nullptr, 0 };
+    return { utf8.data(), WGPU_STRLEN };
+}
+
+WGPUStringView toDawnStringView(const String& string)
+{
+    return toDawnStringView(string.utf8());
+}
+
+String stringFromDawn(WGPUStringView view)
+{
+    if (!view.data)
+        return { };
+    size_t byteLength = view.length == WGPU_STRLEN ? strlen(view.data) : view.length;
+    return String::fromUTF8(std::span<const char> { view.data, byteLength });
+}
+
+String adapterDisplayName(WGPUAdapter adapter)
+{
+    WGPUAdapterInfo info { };
+    if (wgpuAdapterGetInfo(adapter, &info) != WGPUStatus_Success)
+        return "Dawn"_s;
+    String description = stringFromDawn(info.description);
+    String device = stringFromDawn(info.device);
+    wgpuAdapterInfoFreeMembers(info);
+    if (!description.isEmpty())
+        return description;
+    if (!device.isEmpty())
+        return device;
+    return "Dawn"_s;
+}
+
+String dawnFeatureName(WGPUFeatureName feature)
+{
+    switch (feature) {
+    case WGPUFeatureName_CoreFeaturesAndLimits:
+        return "core-features-and-limits"_s;
+    case WGPUFeatureName_DepthClipControl:
+        return "depth-clip-control"_s;
+    case WGPUFeatureName_Depth32FloatStencil8:
