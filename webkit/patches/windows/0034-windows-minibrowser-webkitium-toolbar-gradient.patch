+// Webkitium: sea-foam to salmon native chrome, matching Android MiniBrowser.
+static constexpr COLORREF kWebkitiumChromeStart = RGB(0x9f, 0xe2, 0xbf);
+static constexpr COLORREF kWebkitiumChromeEnd = RGB(0xfa, 0x80, 0x72);
+static constexpr COLORREF kWebkitiumChromeText = RGB(0x1a, 0x1a, 0x1a);
+static constexpr COLORREF kWebkitiumURLBackground = RGB(0xff, 0xf5, 0xf8);
+
+#ifndef DWMWA_CAPTION_COLOR
+#define DWMWA_CAPTION_COLOR 35
+#endif
+#ifndef DWMWA_TEXT_COLOR
+#define DWMWA_TEXT_COLOR 36
+#endif
+#ifndef DWMWA_SYSTEMBACKDROP_TYPE
+#define DWMWA_SYSTEMBACKDROP_TYPE 38
+#endif
+
+static void paintWebkitiumChromeGradient(HDC hdc, const RECT& rect)
+{
+    TRIVERTEX vert[2] { };
+    vert[0].x = rect.left;
+    vert[0].y = rect.top;
+    vert[0].Red = GetRValue(kWebkitiumChromeStart) << 8;
+    vert[0].Green = GetGValue(kWebkitiumChromeStart) << 8;
+    vert[0].Blue = GetBValue(kWebkitiumChromeStart) << 8;
+    vert[1].x = rect.right;
+    vert[1].y = rect.bottom;
+    vert[1].Red = GetRValue(kWebkitiumChromeEnd) << 8;
+    vert[1].Green = GetGValue(kWebkitiumChromeEnd) << 8;
+    vert[1].Blue = GetBValue(kWebkitiumChromeEnd) << 8;
+    GRADIENT_RECT gradientRect { 0, 1 };
+    GradientFill(hdc, vert, 2, &gradientRect, 1, GRADIENT_FILL_RECT_H);
+}
+
+static void enableWebkitiumWindowMaterial(HWND hwnd)
+{
+    const DWORD captionColor = 0x00f8d7df;
+    const DWORD textColor = 0x001a1a1a;
+    DwmSetWindowAttribute(hwnd, DWMWA_CAPTION_COLOR, &captionColor, sizeof(captionColor));
+    DwmSetWindowAttribute(hwnd, DWMWA_TEXT_COLOR, &textColor, sizeof(textColor));
+
+    const DWORD backdropType = 2; // DWM_SYSTEMBACKDROP_TYPE::DWMSBT_MAINWINDOW on Windows 11.
+    DwmSetWindowAttribute(hwnd, DWMWA_SYSTEMBACKDROP_TYPE, &backdropType, sizeof(backdropType));
+}
+
+static void tintNativeMenuBar(HWND hwnd, HBRUSH brush)
+{
+    HMENU menu = GetMenu(hwnd);
+    if (!menu)
+        return;
+
+    MENUINFO info { };
+    info.cbSize = sizeof(info);
+    info.fMask = MIM_BACKGROUND | MIM_APPLYTOSUBMENUS;
+    info.hbrBack = brush;
+    SetMenuInfo(menu, &info);
+    DrawMenuBar(hwnd);
+}
+
+static HICON loadWebkitiumMiniIcon(int size)
+{
+    wchar_t iconPath[MAX_PATH];
+    if (!GetModuleFileName(nullptr, iconPath, _countof(iconPath)))
+        return nullptr;
+    if (!PathRemoveFileSpec(iconPath))
+        return nullptr;
+    if (!PathAppend(iconPath, L"mini_appicon.ico"))
+        return nullptr;
+    return reinterpret_cast<HICON>(LoadImage(nullptr, iconPath, IMAGE_ICON, size, size, LR_LOADFROMFILE));
+}
