+/*
+ * Copyright (C) 2026 The WebKit Authors. All rights reserved.
+ */
+
+#pragma once
+
+#if PLATFORM(WIN) && ENABLE(WEBGPU)
+
+#include "GPU.h"
+#include "GPUCanvasConfiguration.h"
+#include "GPUCanvasContext.h"
+#include "GPUPresentationContext.h"
+#include "ImageBuffer.h"
+#include "GPUTexture.h"
+#include "HTMLCanvasElement.h"
+#include <wtf/Ref.h>
+#include <wtf/RefPtr.h>
+
+#if ENABLE(OFFSCREEN_CANVAS)
+#include "OffscreenCanvas.h"
+#endif
+
+struct HWND__;
+struct HINSTANCE__;
+using HWND = HWND__*;
+using HINSTANCE = HINSTANCE__*;
+
+namespace WebCore {
+
+class Document;
+
+class GPUCanvasContextWin final : public GPUCanvasContext {
+    WTF_MAKE_TZONE_ALLOCATED(GPUCanvasContextWin);
+public:
+    static std::unique_ptr<GPUCanvasContextWin> create(CanvasBase&, GPU&, Document*);
+
+    CanvasType canvas() override;
+    ExceptionOr<void> configure(GPUCanvasConfiguration&&) override;
+    void unconfigure() override;
+    std::optional<GPUCanvasConfiguration> getConfiguration() const override;
+    ExceptionOr<Ref<GPUTexture>> getCurrentTexture() override;
+    void didUpdateCanvasSizeProperties(bool) override;
+    RefPtr<ImageBuffer> surfaceBufferToImageBuffer(SurfaceBuffer) override { return nullptr; }
+    bool isSurfaceBufferTransparentBlack(SurfaceBuffer) const override { return true; }
+
+    void setHostHWND(HWND, uint32_t width, uint32_t height);
+
+private:
+    GPUCanvasContextWin(CanvasBase&, RefPtr<GPUPresentationContext>&&);
+
+    void reconfigureIfNeeded();
+
+    RefPtr<GPUPresentationContext> m_presentationContext;
+    RefPtr<GPU>                    m_gpu;
+    std::optional<GPUCanvasConfiguration> m_configuration;
+    HWND     m_hwnd { nullptr };
+    HINSTANCE m_hinstance { nullptr };
+    uint32_t m_width { 0 };
+    uint32_t m_height { 0 };
+    uint32_t m_frameIndex { 0 };
+    bool     m_dirty { false };
+};
+
+} // namespace WebCore
+
+#endif // PLATFORM(WIN) && ENABLE(WEBGPU)
