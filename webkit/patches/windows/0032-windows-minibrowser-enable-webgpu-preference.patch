Ported from maceip/WebKit-ng (deprecated repo) patch 0020.
Purpose: turn WebGPUEnabled on in MiniBrowser so the runtime probe can see
navigator.gpu without a separate feature-flag step.

Mapped test: harness probeAdapterInfo passes in isolation, but MiniBrowser
hits `navigator.gpu === undefined` until this preference is set.

diff --git a/Tools/MiniBrowser/win/WebKitBrowserWindow.cpp b/Tools/MiniBrowser/win/WebKitBrowserWindow.cpp
--- a/Tools/MiniBrowser/win/WebKitBrowserWindow.cpp
+++ b/Tools/MiniBrowser/win/WebKitBrowserWindow.cpp
@@ -148,6 +148,10 @@ Ref<BrowserWindow> WebKitBrowserWindow::create(BrowserWindowClient& client, HWND
     auto preferences = adoptWK(WKPreferencesCreate());
     WKPreferencesSetMediaCapabilitiesEnabled(preferences.get(), false);
     WKPreferencesSetDeveloperExtrasEnabled(preferences.get(), true);
+#if ENABLE(WEBGPU)
+    auto webGPUFeatureKey = createWKString(L"WebGPUEnabled");
+    WKPreferencesSetExperimentalFeatureForKey(preferences.get(), true, webGPUFeatureKey.get());
+#endif

     auto pageConf = adoptWK(WKPageConfigurationCreate());
     WKPageConfigurationSetWebsiteDataStore(pageConf.get(), websiteDataStore.get());
