 void pushDebugGroup(WGPURenderBundleEncoder o, const String& label) { wgpuRenderBundleEncoderPushDebugGroup(o, toDawnStringView(label)); }
 void insertDebugMarker(WGPURenderBundleEncoder o, const String& label) { wgpuRenderBundleEncoderInsertDebugMarker(o, toDawnStringView(label)); }
 
+WGPUSurface createSurfaceForHWND(WGPUInstance instance, void* hwnd, void* hinstance, const char* label)
+{
+    if (!instance || !hwnd)
+        return nullptr;
+
+    // Dawn v20260410.140140: WGPUSurfaceSourceWindowsHWND (legacy
+    // WGPUSurfaceDescriptorFromWindowsHWND was removed before this release).
+    WGPUSurfaceSourceWindowsHWND fromHwnd { };
+    fromHwnd.chain.next  = nullptr;
+    fromHwnd.chain.sType = WGPUSType_SurfaceSourceWindowsHWND;
+    fromHwnd.hinstance   = hinstance;
+    fromHwnd.hwnd        = hwnd;
+
+    WGPUSurfaceDescriptor desc { };
+    desc.nextInChain = &fromHwnd.chain;
+    desc.label       = WGPUStringView { label, label ? WGPU_STRLEN : 0 };
+
+    return wgpuInstanceCreateSurface(instance, &desc);
+}
+
+bool configureSurface(WGPUSurface surface, WGPUDevice device, WGPUTextureFormat format,
+                      WGPUTextureUsage usage, uint32_t width, uint32_t height)
+{
+    if (!surface || !device)
+        return false;
+    WGPUSurfaceConfiguration cfg { };
+    cfg.device          = device;
+    cfg.format          = format;
+    cfg.usage           = usage;
+    cfg.alphaMode       = WGPUCompositeAlphaMode_Auto;
+    cfg.width           = std::max<uint32_t>(1, width);
+    cfg.height          = std::max<uint32_t>(1, height);
+    cfg.presentMode     = WGPUPresentMode_Fifo;
+    wgpuSurfaceConfigure(surface, &cfg);
+    return true;
+}
+
 } // namespace WebCore::WebGPU::DawnCompat
 
