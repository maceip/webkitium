+#if PLATFORM(WIN) && ENABLE(WEBGPU)
+RefPtr<GPUPresentationContext> GPU::createPresentationContextForHWND(void* hwnd, void* hinstance)
+{
+    RefPtr context = m_backing->createPresentationContextForHWND(hwnd, hinstance);
+    if (!context)
+        return nullptr;
+    return GPUPresentationContext::create(context.releaseNonNull());
+}
