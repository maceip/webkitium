+struct DeviceRequestUserdata {
+    DeviceRequestResult result;
+};
+
+static void adapterRequestDeviceCallback(WGPURequestDeviceStatus status, WGPUDevice device, WGPUStringView message, void* userdata1, void*)
+{
+    auto* userdata = static_cast<DeviceRequestUserdata*>(userdata1);
+    if (!userdata)
+        return;
+
+    userdata->result.status = static_cast<unsigned>(status);
+    userdata->result.message = stringFromDawn(message);
+    userdata->result.succeeded = status == WGPURequestDeviceStatus_Success && device;
+    if (userdata->result.succeeded)
+        userdata->result.device = device;
+    else if (device)
+        wgpuDeviceRelease(device);
+}
+
+DeviceRequestResult adapterRequestDeviceSync(WGPUInstance instance, WGPUAdapter adapter, const CString& label, const CString& defaultQueueLabel)
+{
+    WGPUDeviceDescriptor descriptor { };
+    descriptor.label = toDawnStringView(label);
+    descriptor.defaultQueue.label = toDawnStringView(defaultQueueLabel);
+
+    DeviceRequestUserdata userdata;
+    WGPURequestDeviceCallbackInfo callbackInfo { };
+    callbackInfo.mode = WGPUCallbackMode_AllowProcessEvents;
+    callbackInfo.callback = adapterRequestDeviceCallback;
+    callbackInfo.userdata1 = &userdata;
+
+    auto future = wgpuAdapterRequestDevice(adapter, &descriptor, callbackInfo);
+    waitForFuture(instance, future);
+    return WTF::move(userdata.result);
+}
