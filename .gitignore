var/
workspace/
node_modules/
.env
*.log
tools/noVNC/

# WebKit source-pin tarball and its split parts (7+ GB; distributed via S3 / side-channel).
# Never committed to git — the pin identity lives in config/windows-webgpu-dawn-green.json.
webkit-pin.tar.gz
webkit-pin.tar.gz.part-*

# Scratch pin-verification workspace created by verify-patches.sh.
.tmp/

# CMake / Ninja out-of-source builds (browser/ smoke build lives here).
build/

# SwiftPM intermediates (per-target, sibling to Package.swift).
.build/
.swiftpm/
**/.build/
**/.swiftpm/

# Windows shell MSBuild intermediate + output directories.
# NOTE: the source project lives at chrome/windows/Webkitium/ (capital W) —
# do not blanket-ignore that path; only the explicit bin/obj/intermediate dirs.
chrome/windows/packages/
chrome/windows/x64/
chrome/windows/ARM64/
chrome/windows/Debug/
chrome/windows/Release/
chrome/windows/Generated Files/
chrome/windows/*.user
chrome/windows/Webkitium/bin/
chrome/windows/Webkitium/obj/
chrome/windows/BrowserCore/x64/
chrome/windows/BrowserCore/Debug/
chrome/windows/BrowserCore/Release/
chrome/windows/BrowserCore/bin/
chrome/windows/BrowserCore/obj/
# C++/WinRT header stubs that MSBuild writes at project root during build.
chrome/windows/*_h.h

# Linux Rust/Cargo build artifacts.
chrome/linux/target/
harness_linux/target/

# Android Gradle / NDK / IDE artifacts.
chrome/android/.gradle/
chrome/android/.kotlin/
chrome/android/.idea/
chrome/android/build/
chrome/android/app/build/
chrome/android/app/.cxx/
chrome/android/local.properties

# iOS / Xcode user-local state.
chrome/ios/Webkitium.xcodeproj/xcuserdata/
chrome/ios/Webkitium.xcodeproj/project.xcworkspace/xcuserdata/
chrome/ios/build/
**/DerivedData/
**/*.xcuserstate
