// Swift module definition for browser/color/.
//
// Only exposes the flat C ABI in ColorBridgeC.h to Swift callers -- the
// other C++ headers in this directory (ColorRamp.h, SemanticPalette.h,
// OklchColor.h) would not parse through Swift's Clang importer even
// though they're in the same SPM target's public-headers path.

module WebkitiumColor {
    header "ColorBridgeC.h"
    export *
}
