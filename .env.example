# Runtime state (logs, state.json, *_ACTIVE_BUILD.env): default is $XDG_STATE_HOME/webkitium or ~/.local/state/webkitium.
# Do not point NG_VAR_DIR / WEBKITIUM_STATE_DIR at another repo’s tree — Webkitium ignores known wrong roots and uses the default.
# WEBKITIUM_STATE_DIR=/path/to/state

AWS_REGION=eu-west-1
# S3 artifact bucket for this project lives in eu-central-1 (SSM may still use eu-west-1).
NG_ARTIFACT_UPLOAD_REGION=eu-central-1
NG_ARTIFACT_BUCKET=s3://cory-build-artifacts-euc1-095713295645-20260407/webkitium

# Alerts: stderr + bell; optional Slack-compatible incoming webhook (JSON {"text":"..."}).
# NG_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# Optional: run a shell snippet with NG_ALERT_MESSAGE set (e.g. pager).
# NG_ALERT_CMD='echo "$NG_ALERT_MESSAGE" | mail -s alert you@example.com'

# Windows: after N marker polls (~90s each), if still RUNNING but no artifacts/, notify once (worker died early).
# Set to 0 to disable.
NG_WINDOWS_ALERT_AFTER_POLLS=5

ANDROID_HOME=/home/ubuntu/Android/Sdk
NG_ANDROID_SOURCE=/home/ubuntu/webkit/wpe-android
NG_ANDROID_ARCH=arm64
NG_ANDROID_BUILD_DEPS=0
# Android: default is remote SSM. Set NG_ANDROID_LOCAL=1 for Gradle on this host only.
NG_ANDROID_REGION=eu-central-1
# Optional; defaults to i-08a3afbbac86a0002 (see config/build-machines.json).
# NG_ANDROID_INSTANCE_ID=i-08a3afbbac86a0002
# NG_ANDROID_DEFAULT_INSTANCE_ID=i-08a3afbbac86a0002
# SDK path on the **remote** builder (not the orchestrator laptop's ANDROID_HOME).
NG_ANDROID_BUILDER_ANDROID_HOME=/home/ubuntu/Android/Sdk
# NG_ANDROID_LOCAL=1
# NG_ANDROID_WORKDIR=/home/ubuntu/webkitium-bootstrap/webkitium-<build-id>

NG_WINDOWS_INSTANCE_ID=i-0d254760fe07c5e9f
NG_WINDOWS_INSTANCE_NAME=webkit-win-build-20260412
NG_WINDOWS_WORKDIR=C:\Bootstrap\webkitium
NG_WINDOWS_BASELINE_S3=s3://cory-build-artifacts-euc1-095713295645-20260407/webkit/windows-build29-20260413
NG_WINDOWS_ARTIFACT_S3=s3://cory-build-artifacts-euc1-095713295645-20260407/webkitium/windows
NG_WINDOWS_SOURCE=C:\Work\WebKit
NG_WINDOWS_OUTPUT=C:\Work\WebKit\WebKitBuild\Release
NG_WINDOWS_BOOTSTRAP=C:\Bootstrap
NG_WINDOWS_VCPKG=C:\vcpkg
NG_WINDOWS_BUILD_TOOLS=C:\BuildTools
NG_WINDOWS_RUBY=C:\Ruby34-x64
NG_WINDOWS_LLVM=C:\Program Files\LLVM
NG_WINDOWS_GIT=C:\Program Files\Git\cmd
NG_WINDOWS_TOOLBIN=C:\Bootstrap\toolbin
NG_WINDOWS_BUILD_COMMAND=perl C:\Work\WebKit\Tools\Scripts\build-webkit --release --wincairo

NG_MACOS_REGION=eu-central-1
NG_MACOS_HOST_ID=h-0fe6b0782f40a6c69
NG_MACOS_INSTANCE_ID=i-092d7452a5deac519
NG_MACOS_INSTANCE_TYPE=mac2-m2.metal
NG_MACOS_SOURCE=/Users/ec2-user/Work/WebKit
NG_MACOS_OUTPUT=/Users/ec2-user/Work/WebKit/WebKitBuild/Release
NG_MACOS_ARTIFACT_S3=s3://cory-build-artifacts-euc1-095713295645-20260407/webkitium/macos
