{
  "$version": "2.0.0",
  "$description": "Android 15+ overrides. We do NOT use Material You dynamic color, wallpaper-derived palettes, or any Material Color Utilities scheme. Our palette comes from browser/color/ColorRamp.cpp. Edge-to-edge and predictive back are assumed.",
  "$extensions": {
    "dev.webkitium.protection": "platform-only",
    "dev.webkitium.platform": ["android"]
  },
  "colorSource": {
    "$description": "Always 'webkitium'. No wallpaper extraction. No DynamicColors.applyToActivitiesIfAvailable().",
    "$type": "number",
    "$value": 0
  },
  "material": {
    "omnibar": {
      "$type": "material",
      "$description": "Compose Surface with tonalElevation=3.dp, shape.roundedCorner(28.dp). Floats above content (edge-to-edge).",
      "$value": {
        "kind": "Surface",
        "tonalElevation": 3,
        "color": "{surface.chromeRaised}",
        "shape": "roundedCorner:{shape.omnibar}"
      }
    },
    "contextMenu": {
      "$type": "material",
      "$description": "DropdownMenu with elevation=2. No blur; solid surface by design (avoids Material 3 default look).",
      "$value": { "kind": "Surface", "tonalElevation": 2, "color": "{surface.overlay}" }
    }
  },
  "haptics": {
    "$description": "HapticFeedbackConstants. Honors per-device haptic settings.",
    "omnibarSubmit":   { "$type": "haptic", "$value": "CONFIRM" },
    "tabSwitch":       { "$type": "haptic", "$value": "SEGMENT_TICK" },
    "contextMenuOpen": { "$type": "haptic", "$value": "CONTEXT_CLICK" }
  },
  "shape": {
    "omnibar":     { "$type": "dimension", "$value": "28px" },
    "contextMenu": { "$type": "dimension", "$value": "12px" }
  },
  "predictiveBack": {
    "enabled": { "$type": "number", "$value": 1 }
  }
}
