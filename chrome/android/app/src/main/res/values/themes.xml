<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Minimal Activity theme. UI is Compose; this only colours the system
      bars before setContent runs and provides the splash background.
      enableEdgeToEdge() at runtime selects the right status-bar appearance
      for the current Configuration.uiMode, so we deliberately do NOT pin
      windowLightStatusBar / windowLightNavigationBar here — pinning them
      to true breaks dark-mode legibility.
    -->
    <style name="Theme.Webkitium" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.Webkitium.NoActionBar" parent="Theme.Webkitium" />
</resources>
