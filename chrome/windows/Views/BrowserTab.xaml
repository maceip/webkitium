<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Webkitium.Views.BrowserTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        One tab's content is just the WebView2 surface. The omnibar
        moved to the window's title-bar strip; tabs only own the
        web-content area.
    -->
    <Border Background="{ThemeResource SurfaceCanvas}"
            CornerRadius="10"
            Margin="8,0,8,8">
        <WebView2 x:Name="PART_WebView"
                  DefaultBackgroundColor="Transparent" />
    </Border>
</UserControl>
