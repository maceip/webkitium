<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Webkitium.Views.BrowserTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Webkitium.Views">

    <!--
        One tab's content: omnibar at the top, WebView2 below.
        Each tab owns its own omnibar per user feedback (omnibar sits
        at the tab level, not the window level).
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Per-tab omnibar. -->
        <Grid Grid.Row="0" Padding="12,4,12,4">
            <views:Omnibar x:Name="PART_Omnibar"
                           HorizontalAlignment="Stretch" />
        </Grid>

        <!-- Per-tab WebView2 content host. -->
        <Border Grid.Row="1"
                Background="{ThemeResource SurfaceCanvas}"
                CornerRadius="10"
                Margin="8,0,8,8">
            <WebView2 x:Name="PART_WebView"
                      DefaultBackgroundColor="Transparent" />
        </Border>
    </Grid>
</UserControl>
