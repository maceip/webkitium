<?xml version="1.0" encoding="utf-8"?>
<packages>
  <package id="Microsoft.Windows.CppWinRT" version="2.0.240405.15" targetFramework="native" />
  <package id="Microsoft.WindowsAppSDK" version="1.6.250402001" targetFramework="native" />
  <!-- WindowsAppSDK's Microsoft.UI.Xaml.winmd references
       Microsoft.Web.WebView2.Core.CoreWebView2, so cppwinrt needs this
       package to generate projections even when the shell does not
       itself instantiate a WebView2. -->
  <package id="Microsoft.Web.WebView2" version="1.0.2592.51" targetFramework="native" />
</packages>
