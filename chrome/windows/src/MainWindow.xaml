<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="webkitium.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:webkitium">

    <!--
        Mica backdrop declared in XAML. Kind="Base" means the system material
        renders without a brand tint — brand accent shows up in discrete
        surfaces (omnibar focus ring, buttons, selection) rather than being
        smeared across the whole window. This keeps the chrome feeling
        Windows-native while the brand still comes through clearly at the
        point of interaction.
    -->
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Title bar + omnibar band -->
            <RowDefinition Height="*" />     <!-- Web content / placeholder -->
        </Grid.RowDefinitions>

        <!--
            Title bar band. OmnibarHost is registered with SetTitleBar() in
            code-behind so the OS knows this region is draggable. The pill
            itself sits in the middle; space on either side is draggable
            title-bar blank.
        -->
        <Grid x:Name="OmnibarHost"
              Grid.Row="0"
              Height="44"
              Padding="{StaticResource Space2, x:Double}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />  <!-- System controls reserve -->
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>

            <local:Omnibar Grid.Column="1"
                           MaxWidth="720"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Center" />
        </Grid>

        <!--
            Content surface. When we wire WebView2 + the WebKit Windows port,
            this Border gets replaced with the content view. For now it is a
            SurfaceCanvas-filled placeholder so the layout is visible.
        -->
        <Border Grid.Row="1"
                Background="{ThemeResource SurfaceCanvas}"
                CornerRadius="{StaticResource RadiusMd, x:Double}"
                Margin="8,0,8,8">
            <TextBlock Text="Web content goes here"
                       Foreground="{ThemeResource TextTertiary}"
                       FontFamily="{StaticResource FontFamilyUI}"
                       FontSize="{StaticResource FontSizeBody, x:Double}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>
