<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="webkitium.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--
                    Webkitium semantic tokens. ThemeDictionaries inside this
                    file carry the Light/Dark variants; WinUI resolves them
                    automatically based on system appearance.
                -->
                <ResourceDictionary Source="ms-appx:///src/Tokens.xaml" />

                <!--
                    WinUI default styles remain available. Component styles
                    are applied at use-sites via {StaticResource …} rather
                    than a BasedOn cascade — we don't re-skin every WinUI
                    control, we only style the chrome surfaces we own.
                -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
