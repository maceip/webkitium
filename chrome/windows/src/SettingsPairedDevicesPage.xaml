<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="webkitium.SettingsPairedDevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <ScrollViewer Padding="32,16,32,32">
        <StackPanel Spacing="24" MaxWidth="720" HorizontalAlignment="Left">

            <TextBlock Text="Paired devices"
                       FontFamily="{StaticResource FontFamilyUI}"
                       FontSize="{StaticResource FontSizeTitle1, x:Double}"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextPrimary}" />

            <TextBlock
                Text="Devices signed in to your webkitium account appear here. Sync traffic flows through the loopback server at browser/sync/LoopbackSyncServer until the cloud sync transport is wired."
                FontFamily="{StaticResource FontFamilyUI}"
                FontSize="{StaticResource FontSizeBody, x:Double}"
                Foreground="{ThemeResource TextSecondary}"
                TextWrapping="Wrap" />

            <!--
                Mock device list.  When the C++/WinRT bridge for
                browser/sync lands, an ItemsRepeater bound to the live
                SyncClient registry replaces this StackPanel.
            -->
            <StackPanel Spacing="8">
                <TextBlock Text="CURRENTLY CONNECTED"
                           FontSize="{StaticResource FontSizeFootnote, x:Double}"
                           Foreground="{ThemeResource TextTertiary}"
                           CharacterSpacing="80"
                           FontWeight="SemiBold" />

                <Border Background="{ThemeResource SurfaceChromeRaised}"
                        CornerRadius="{StaticResource RadiusMd, x:Double}"
                        BorderBrush="{ThemeResource BorderSubtle}"
                        BorderThickness="1"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0"
                                  Glyph="&#xE7F8;"
                                  FontFamily="Segoe Fluent Icons"
                                  FontSize="20"
                                  Foreground="{ThemeResource AccentFill}"
                                  Margin="0,0,12,0"
                                  VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Work Laptop"
                                       FontSize="{StaticResource FontSizeBody, x:Double}"
                                       Foreground="{ThemeResource TextPrimary}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Bookmarks, Tabs, Passkeys • last sync 2m ago"
                                       FontSize="{StaticResource FontSizeFootnote, x:Double}"
                                       Foreground="{ThemeResource TextSecondary}" />
                        </StackPanel>
                        <Border Grid.Column="2"
                                Background="{ThemeResource AccentFillSubtle}"
                                CornerRadius="{StaticResource RadiusSm, x:Double}"
                                Padding="6,2">
                            <TextBlock Text="This device"
                                       FontSize="{StaticResource FontSizeFootnote, x:Double}"
                                       Foreground="{ThemeResource AccentFill}" />
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="OTHER DEVICES"
                           FontSize="{StaticResource FontSizeFootnote, x:Double}"
                           Foreground="{ThemeResource TextTertiary}"
                           CharacterSpacing="80"
                           FontWeight="SemiBold" />

                <Border Background="{ThemeResource SurfaceChromeRaised}"
                        CornerRadius="{StaticResource RadiusMd, x:Double}"
                        BorderBrush="{ThemeResource BorderSubtle}"
                        BorderThickness="1"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0"
                                      Glyph="&#xE8EA;"
                                      FontFamily="Segoe Fluent Icons"
                                      FontSize="20"
                                      Foreground="{ThemeResource TextSecondary}"
                                      Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Phone"
                                           FontSize="{StaticResource FontSizeBody, x:Double}"
                                           Foreground="{ThemeResource TextPrimary}" />
                                <TextBlock Text="Bookmarks, Tabs • last sync 17s ago"
                                           FontSize="{StaticResource FontSizeFootnote, x:Double}"
                                           Foreground="{ThemeResource TextSecondary}" />
                            </StackPanel>
                            <FontIcon Grid.Column="2"
                                      Glyph="&#xE76C;"
                                      FontFamily="Segoe Fluent Icons"
                                      FontSize="12"
                                      Foreground="{ThemeResource TextTertiary}" />
                        </Grid>

                        <Rectangle Height="1" Fill="{ThemeResource BorderSubtle}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0"
                                      Glyph="&#xE977;"
                                      FontFamily="Segoe Fluent Icons"
                                      FontSize="20"
                                      Foreground="{ThemeResource TextSecondary}"
                                      Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Personal iMac"
                                           FontSize="{StaticResource FontSizeBody, x:Double}"
                                           Foreground="{ThemeResource TextPrimary}" />
                                <TextBlock Text="Bookmarks, Passkeys • last sync 3h ago"
                                           FontSize="{StaticResource FontSizeFootnote, x:Double}"
                                           Foreground="{ThemeResource TextSecondary}" />
                            </StackPanel>
                            <FontIcon Grid.Column="2"
                                      Glyph="&#xE76C;"
                                      FontFamily="Segoe Fluent Icons"
                                      FontSize="12"
                                      Foreground="{ThemeResource TextTertiary}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Background="{ThemeResource SurfaceChromeRaised}"
                    CornerRadius="{StaticResource RadiusMd, x:Double}"
                    BorderBrush="{ThemeResource BorderSubtle}"
                    BorderThickness="1"
                    Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="Loopback sync server"
                               FontSize="{StaticResource FontSizeBody, x:Double}"
                               Foreground="{ThemeResource TextPrimary}"
                               FontWeight="SemiBold" />
                    <TextBlock FontSize="{StaticResource FontSizeFootnote, x:Double}"
                               Foreground="{ThemeResource TextSecondary}"
                               TextWrapping="Wrap">
                        Running on localhost. All sync traffic is visible at chrome://sync-internals in a future build. Chromium-shaped wire format — no vendor server involved.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
