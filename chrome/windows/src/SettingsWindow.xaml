<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="webkitium.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:webkitium"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <!--
        MicaAlt backdrop per design/tokens/platform-overrides/windows.tokens.json.
        MicaAlt is visually more saturated than base Mica and is the Windows
        11 convention for Settings-class surfaces (e.g. the system Settings
        app itself uses MicaAlt).
    -->
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Title-bar reserve -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Empty draggable title-bar strip.  SetTitleBar in code-behind. -->
        <Grid x:Name="TitleBarStrip"
              Grid.Row="0"
              Height="32">
            <TextBlock Text="Settings"
                       Margin="16,6,0,0"
                       Foreground="{ThemeResource TextSecondary}"
                       FontFamily="{StaticResource FontFamilyUI}"
                       FontSize="{StaticResource FontSizeFootnote}"
                       VerticalAlignment="Top" />
        </Grid>

        <muxc:NavigationView
            Grid.Row="1"
            x:Name="Nav"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="220"
            SelectionChanged="OnNavigationSelectionChanged"
            Background="Transparent">

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem
                    x:Name="PairedDevicesItem"
                    Content="Paired devices"
                    Tag="paired-devices"
                    IsSelected="True">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8CC;" FontFamily="Segoe Fluent Icons" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>

                <muxc:NavigationViewItem
                    x:Name="ThemeItem"
                    Content="Theme"
                    Tag="theme">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE790;" FontFamily="Segoe Fluent Icons" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>

                <muxc:NavigationViewItem
                    x:Name="PasswordsItem"
                    Content="Passwords"
                    Tag="passwords">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE72E;" FontFamily="Segoe Fluent Icons" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </muxc:NavigationView>
    </Grid>
</Window>
