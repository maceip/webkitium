<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="webkitium.SettingsThemePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Theme page.  The ColorPicker is live-wired to
        PaletteProvider::ApplySeed -- every color change regenerates the
        palette via browser/color/ColorRamp.cpp and repaints the app.
    -->

    <ScrollViewer Padding="32,16,32,32">
        <StackPanel Spacing="24" MaxWidth="720" HorizontalAlignment="Left">

            <TextBlock Text="Theme"
                       FontFamily="{StaticResource FontFamilyUI}"
                       FontSize="{StaticResource FontSizeTitle1, x:Double}"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextPrimary}" />

            <TextBlock FontFamily="{StaticResource FontFamilyUI}"
                       FontSize="{StaticResource FontSizeBody, x:Double}"
                       Foreground="{ThemeResource TextSecondary}"
                       TextWrapping="Wrap">
                Pick a single brand color. Webkitium derives a 24-step palette
                from it (12 light + 12 dark) using an OKLCH perceptually-uniform
                ramp. Your choice syncs to every device signed in to this
                account — the same color drives your address bar on Windows,
                macOS, and Android.
            </TextBlock>

            <!-- Current seed readout -->
            <Border Background="{ThemeResource SurfaceChromeRaised}"
                    CornerRadius="{StaticResource RadiusMd, x:Double}"
                    BorderBrush="{ThemeResource BorderSubtle}"
                    BorderThickness="1"
                    Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Current brand color"
                                   FontSize="{StaticResource FontSizeBody, x:Double}"
                                   Foreground="{ThemeResource TextPrimary}"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="CurrentSeedHex"
                                   Text="#1F5AE0"
                                   FontFamily="{StaticResource FontFamilyMono}"
                                   FontSize="{StaticResource FontSizeFootnote, x:Double}"
                                   Foreground="{ThemeResource TextSecondary}" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            x:Name="CurrentSeedSwatch"
                            Width="64"
                            Height="32"
                            CornerRadius="{StaticResource RadiusSm, x:Double}"
                            BorderBrush="{ThemeResource BorderDefault}"
                            BorderThickness="1" />
                </Grid>
            </Border>

            <!-- Presets -->
            <StackPanel Spacing="12">
                <TextBlock Text="PRESETS"
                           FontSize="{StaticResource FontSizeFootnote, x:Double}"
                           Foreground="{ThemeResource TextTertiary}"
                           CharacterSpacing="80"
                           FontWeight="SemiBold" />

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button x:Name="PresetBlueButton"
                            Click="OnPresetClicked"
                            Tag="#FF1F5AE0"
                            Width="80"
                            Height="48"
                            Padding="0"
                            CornerRadius="{StaticResource RadiusMd, x:Double}"
                            Background="#FF1F5AE0"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Webkitium blue (default)" />
                    <Button x:Name="PresetMagentaButton"
                            Click="OnPresetClicked"
                            Tag="#FFD21F6B"
                            Width="80"
                            Height="48"
                            Padding="0"
                            CornerRadius="{StaticResource RadiusMd, x:Double}"
                            Background="#FFD21F6B"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Magenta" />
                    <Button x:Name="PresetGreenButton"
                            Click="OnPresetClicked"
                            Tag="#FF2D7A3E"
                            Width="80"
                            Height="48"
                            Padding="0"
                            CornerRadius="{StaticResource RadiusMd, x:Double}"
                            Background="#FF2D7A3E"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Forest green" />
                    <Button x:Name="PresetMonoButton"
                            Click="OnPresetClicked"
                            Tag="#FF454B55"
                            Width="80"
                            Height="48"
                            Padding="0"
                            CornerRadius="{StaticResource RadiusMd, x:Double}"
                            Background="#FF454B55"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Near-monochrome" />
                </StackPanel>
            </StackPanel>

            <!-- Custom picker -->
            <StackPanel Spacing="12">
                <TextBlock Text="CUSTOM"
                           FontSize="{StaticResource FontSizeFootnote, x:Double}"
                           Foreground="{ThemeResource TextTertiary}"
                           CharacterSpacing="80"
                           FontWeight="SemiBold" />

                <ColorPicker x:Name="SeedPicker"
                             Color="#FF1F5AE0"
                             IsAlphaEnabled="False"
                             IsColorChannelTextInputVisible="True"
                             IsHexInputVisible="True"
                             IsColorSpectrumVisible="True"
                             ColorSpectrumShape="Box"
                             ColorChanged="OnSeedPickerColorChanged" />
            </StackPanel>

            <!-- Appearance (stub — WinUI follows system, no app-level override yet) -->
            <Border Background="{ThemeResource SurfaceChromeRaised}"
                    CornerRadius="{StaticResource RadiusMd, x:Double}"
                    BorderBrush="{ThemeResource BorderSubtle}"
                    BorderThickness="1"
                    Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Appearance"
                               FontSize="{StaticResource FontSizeBody, x:Double}"
                               Foreground="{ThemeResource TextPrimary}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Follows your Windows appearance setting. Per-app light/dark override lands when sync carries the preference."
                               FontSize="{StaticResource FontSizeFootnote, x:Double}"
                               Foreground="{ThemeResource TextSecondary}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
