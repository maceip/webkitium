<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="webkitium.SettingsPasswordsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32,16,32,32">
        <StackPanel Spacing="24" MaxWidth="720" HorizontalAlignment="Left">

            <TextBlock Text="Passwords"
                       FontFamily="{StaticResource FontFamilyUI}"
                       FontSize="{StaticResource FontSizeTitle1}"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextPrimary}" />

            <TextBlock FontFamily="{StaticResource FontFamilyUI}"
                       FontSize="{StaticResource FontSizeBody}"
                       Foreground="{ThemeResource TextSecondary}"
                       TextWrapping="Wrap">
                Debug trace of recent WebAuthn ceremonies. The real authenticator
                chrome never lives here — it runs in a separate browser-process
                window (design/components/authenticator/SECURITY_BOUNDARY.md).
                This page is the diagnostic view, not the auth surface.
            </TextBlock>

            <!-- Counters (mock) -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{ThemeResource SurfaceChromeRaised}"
                        CornerRadius="{StaticResource RadiusMd}"
                        BorderBrush="{ThemeResource BorderSubtle}"
                        BorderThickness="1"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="12"
                                   FontSize="{StaticResource FontSizeTitle2}"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentFill}" />
                        <TextBlock Text="Saved passkeys"
                                   FontSize="{StaticResource FontSizeFootnote}"
                                   Foreground="{ThemeResource TextSecondary}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{ThemeResource SurfaceChromeRaised}"
                        CornerRadius="{StaticResource RadiusMd}"
                        BorderBrush="{ThemeResource BorderSubtle}"
                        BorderThickness="1"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="4"
                                   FontSize="{StaticResource FontSizeTitle2}"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextPrimary}" />
                        <TextBlock Text="Ceremonies in last 24h"
                                   FontSize="{StaticResource FontSizeFootnote}"
                                   Foreground="{ThemeResource TextSecondary}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="{ThemeResource SurfaceChromeRaised}"
                        CornerRadius="{StaticResource RadiusMd}"
                        BorderBrush="{ThemeResource BorderSubtle}"
                        BorderThickness="1"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="1"
                                   FontSize="{StaticResource FontSizeTitle2}"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextDanger}" />
                        <TextBlock Text="Rejected (RP mismatch)"
                                   FontSize="{StaticResource FontSizeFootnote}"
                                   Foreground="{ThemeResource TextSecondary}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Event log (mock).  Bound to WebAuthnController::eventLog()
                 when the C++/WinRT bridge is implemented. -->
            <StackPanel Spacing="12">
                <TextBlock Text="RECENT CEREMONIES"
                           FontSize="{StaticResource FontSizeFootnote}"
                           Foreground="{ThemeResource TextTertiary}"
                           CharacterSpacing="80"
                           FontWeight="SemiBold" />

                <Border Background="{ThemeResource SurfaceChromeRaised}"
                        CornerRadius="{StaticResource RadiusMd}"
                        BorderBrush="{ThemeResource BorderSubtle}"
                        BorderThickness="1">
                    <StackPanel>
                        <!-- Row 1: success get -->
                        <Grid Padding="16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="12:34:56"
                                       FontFamily="{StaticResource FontFamilyMono}"
                                       FontSize="{StaticResource FontSizeFootnote}"
                                       Foreground="{ThemeResource TextSecondary}"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="get • example.com"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{ThemeResource TextPrimary}" />
                                <TextBlock Text="credential abc123… • Touch ID"
                                           FontFamily="{StaticResource FontFamilyMono}"
                                           FontSize="{StaticResource FontSizeFootnote}"
                                           Foreground="{ThemeResource TextTertiary}" />
                            </StackPanel>
                            <Border Grid.Column="2"
                                    Background="#22" CornerRadius="{StaticResource RadiusSm}"
                                    Padding="8,2"
                                    VerticalAlignment="Center">
                                <TextBlock Text="Success"
                                           FontSize="{StaticResource FontSizeFootnote}"
                                           Foreground="{ThemeResource AccentFill}" />
                            </Border>
                        </Grid>
                        <Rectangle Height="1" Fill="{ThemeResource BorderSubtle}" />

                        <!-- Row 2: create -->
                        <Grid Padding="16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="12:33:12"
                                       FontFamily="{StaticResource FontFamilyMono}"
                                       FontSize="{StaticResource FontSizeFootnote}"
                                       Foreground="{ThemeResource TextSecondary}"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="create • bank.com"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{ThemeResource TextPrimary}" />
                                <TextBlock Text="new credential • Windows Hello"
                                           FontFamily="{StaticResource FontFamilyMono}"
                                           FontSize="{StaticResource FontSizeFootnote}"
                                           Foreground="{ThemeResource TextTertiary}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="Success"
                                       FontSize="{StaticResource FontSizeFootnote}"
                                       Foreground="{ThemeResource AccentFill}"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Rectangle Height="1" Fill="{ThemeResource BorderSubtle}" />

                        <!-- Row 3: rejected -->
                        <Grid Padding="16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="12:30:45"
                                       FontFamily="{StaticResource FontFamilyMono}"
                                       FontSize="{StaticResource FontSizeFootnote}"
                                       Foreground="{ThemeResource TextSecondary}"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="get • totally-not-paypal.example"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{ThemeResource TextPrimary}" />
                                <TextBlock Text="rp id mismatch • origin policy"
                                           FontFamily="{StaticResource FontFamilyMono}"
                                           FontSize="{StaticResource FontSizeFootnote}"
                                           Foreground="{ThemeResource TextDanger}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="Rejected"
                                       FontSize="{StaticResource FontSizeFootnote}"
                                       Foreground="{ThemeResource TextDanger}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Background="{ThemeResource SurfaceChromeRaised}"
                    CornerRadius="{StaticResource RadiusMd}"
                    BorderBrush="{ThemeResource BorderSubtle}"
                    BorderThickness="1"
                    Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="Where this page doesn't go"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{ThemeResource TextPrimary}"
                               FontWeight="SemiBold" />
                    <TextBlock FontSize="{StaticResource FontSizeFootnote}"
                               Foreground="{ThemeResource TextSecondary}"
                               TextWrapping="Wrap">
                        The real password manager — autofill, passkey storage, per-site
                        detail — is a separate window drawn by the browser process, not
                        a page in Settings. Settings reveals the log; it does not
                        reveal the credentials.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
