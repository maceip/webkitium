<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="webkitium.Omnibar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Omnibar per design/components/omnibar/SPEC.md:

            [lockmark] [origin chip] [input / inline suggestion] [actions]

        The pill owns the visual (Background, Border, CornerRadius).
        The nested TextBox is forced transparent and has its
        TextControl* theme resources overridden so that our Foreground
        brushes actually apply.  Without those overrides the default
        TextBox template wins and the text is invisible on our pill.

        MaxWidth lives on the Border, not the UserControl, so the
        parent Stretch layout is bounded at the pill level.
    -->

    <Border x:Name="PART_Pill"
            Background="{ThemeResource SurfaceSunken}"
            BorderBrush="{ThemeResource BorderSubtle}"
            BorderThickness="1"
            CornerRadius="10"
            MaxWidth="720"
            Padding="8,4"
            HorizontalAlignment="Stretch">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />   <!-- Lockmark -->
                <ColumnDefinition Width="*" />      <!-- Input -->
                <ColumnDefinition Width="Auto" />   <!-- Actions -->
            </Grid.ColumnDefinitions>

            <FontIcon Grid.Column="0"
                      x:Name="PART_Lockmark"
                      Glyph="&#xE72E;"
                      FontFamily="Segoe Fluent Icons"
                      FontSize="14"
                      Foreground="{ThemeResource AccentFill}"
                      Margin="4,0,8,0"
                      VerticalAlignment="Center" />

            <TextBox Grid.Column="1"
                     x:Name="PART_Input"
                     PlaceholderText="Search or enter address"
                     FontFamily="{StaticResource FontFamilyUI}"
                     FontSize="{StaticResource FontSizeBody}"
                     VerticalAlignment="Center"
                     VerticalContentAlignment="Center"
                     BorderThickness="0"
                     GotFocus="OnInputGotFocus"
                     LostFocus="OnInputLostFocus"
                     KeyDown="OnInputKeyDown">
                <TextBox.Resources>
                    <!-- Override every TextControl* brush so the default
                         template never paints its own background or fills
                         in its own foreground.  These override our outer
                         Foreground= attribute (which TextBox ignores). -->
                    <SolidColorBrush x:Key="TextControlForeground" Color="{ThemeResource Neutral12}" />
                    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="{ThemeResource Neutral12}" />
                    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{ThemeResource Neutral12}" />
                    <SolidColorBrush x:Key="TextControlForegroundDisabled" Color="{ThemeResource Neutral9}" />
                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="{ThemeResource Neutral9}" />
                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="{ThemeResource Neutral9}" />
                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="{ThemeResource Neutral9}" />

                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />

                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />

                    <!-- Hide the blue focus underline the default template
                         would draw beneath the text; our pill border
                         already indicates focus. -->
                    <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                    <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>

                    <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="{ThemeResource AccentFill}" />
                    <SolidColorBrush x:Key="TextControlButtonForeground" Color="{ThemeResource Neutral9}" />
                    <SolidColorBrush x:Key="TextControlButtonForegroundPointerOver" Color="{ThemeResource Brand11}" />
                </TextBox.Resources>
            </TextBox>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="0">
                <Button x:Name="PART_Reload"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Padding="6"
                        ToolTipService.ToolTip="Reload (Ctrl+R)">
                    <FontIcon Glyph="&#xE72C;"
                              FontFamily="Segoe Fluent Icons"
                              FontSize="14"
                              Foreground="{ThemeResource TextSecondary}" />
                </Button>
                <Button x:Name="PART_Extensions"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Padding="6"
                        ToolTipService.ToolTip="Extensions">
                    <FontIcon Glyph="&#xECAA;"
                              FontFamily="Segoe Fluent Icons"
                              FontSize="14"
                              Foreground="{ThemeResource TextSecondary}" />
                </Button>
                <Button x:Name="PART_Overflow"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Padding="6"
                        ToolTipService.ToolTip="More">
                    <FontIcon Glyph="&#xE712;"
                              FontFamily="Segoe Fluent Icons"
                              FontSize="14"
                              Foreground="{ThemeResource TextSecondary}" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
