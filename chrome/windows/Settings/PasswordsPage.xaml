<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Webkitium.Settings.PasswordsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <ScrollViewer Padding="36,24,36,32">
        <StackPanel MaxWidth="1064" Spacing="4">
            <TextBlock Text="Passwords"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextPrimary}"
                       Margin="1,0,0,8" />
            <TextBlock
                Text="Debug view of recent WebAuthn ceremonies. The authenticator chrome itself is drawn by the browser process in a separate window and is not themeable (see design/components/authenticator/SECURITY_BOUNDARY.md)."
                Foreground="{ThemeResource TextSecondary}"
                TextWrapping="Wrap"
                Margin="1,0,0,24" />

            <TextBlock Text="Activity summary"
                       Foreground="{ThemeResource TextTertiary}"
                       FontSize="12"
                       CharacterSpacing="80"
                       FontWeight="SemiBold"
                       Margin="1,16,0,6" />

            <controls:SettingsCard Header="Saved passkeys" Description="12 credentials across 9 sites">
                <controls:SettingsCard.HeaderIcon>
                    <SymbolIcon Symbol="Permissions" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>

            <controls:SettingsCard Header="Ceremonies in last 24 hours"
                                   Description="4 successful  ·  1 rejected">
                <controls:SettingsCard.HeaderIcon>
                    <SymbolIcon Symbol="Calendar" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>

            <TextBlock Text="Recent ceremonies"
                       Foreground="{ThemeResource TextTertiary}"
                       FontSize="12"
                       CharacterSpacing="80"
                       FontWeight="SemiBold"
                       Margin="1,24,0,6" />

            <controls:SettingsCard Header="get  ·  example.com"
                                   Description="12:34:56  ·  credential abc123…  ·  Touch ID">
                <controls:SettingsCard.HeaderIcon>
                    <SymbolIcon Symbol="Accept" />
                </controls:SettingsCard.HeaderIcon>
                <TextBlock Text="Success"
                           Foreground="{ThemeResource AccentFill}" />
            </controls:SettingsCard>

            <controls:SettingsCard Header="create  ·  bank.com"
                                   Description="12:33:12  ·  new credential  ·  Windows Hello">
                <controls:SettingsCard.HeaderIcon>
                    <SymbolIcon Symbol="Add" />
                </controls:SettingsCard.HeaderIcon>
                <TextBlock Text="Success"
                           Foreground="{ThemeResource AccentFill}" />
            </controls:SettingsCard>

            <controls:SettingsCard Header="get  ·  totally-not-paypal.example"
                                   Description="12:30:45  ·  rp id mismatch">
                <controls:SettingsCard.HeaderIcon>
                    <SymbolIcon Symbol="Cancel" />
                </controls:SettingsCard.HeaderIcon>
                <TextBlock Text="Rejected"
                           Foreground="{ThemeResource TextDanger}" />
            </controls:SettingsCard>
        </StackPanel>
    </ScrollViewer>
</Page>
