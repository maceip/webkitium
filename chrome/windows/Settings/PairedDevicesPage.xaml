<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Webkitium.Settings.PairedDevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <ScrollViewer Padding="36,24,36,32">
        <StackPanel MaxWidth="1064" Spacing="4">
            <TextBlock Text="Paired devices"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextPrimary}"
                       Margin="1,0,0,8" />
            <TextBlock
                Text="Devices signed in to your webkitium account sync bookmarks, tabs, and passkeys through the loopback sync server. Real cloud transport arrives when the Chromium-shaped wire protocol is productionized."
                Foreground="{ThemeResource TextSecondary}"
                TextWrapping="Wrap"
                Margin="1,0,0,24" />

            <TextBlock Text="Currently connected"
                       Foreground="{ThemeResource TextTertiary}"
                       FontSize="12"
                       CharacterSpacing="80"
                       FontWeight="SemiBold"
                       Margin="1,16,0,6" />

            <controls:SettingsCard Header="Work Laptop"
                                   Description="Bookmarks, Tabs, Passkeys  ·  last sync 2m ago">
                <controls:SettingsCard.HeaderIcon>
                    <SymbolIcon Symbol="GoToStart" />
                </controls:SettingsCard.HeaderIcon>
                <Border Background="{ThemeResource AccentFillSubtle}"
                        CornerRadius="6"
                        Padding="8,3">
                    <TextBlock Text="This device"
                               Foreground="{ThemeResource AccentFill}"
                               FontSize="12" />
                </Border>
            </controls:SettingsCard>

            <TextBlock Text="Other devices"
                       Foreground="{ThemeResource TextTertiary}"
                       FontSize="12"
                       CharacterSpacing="80"
                       FontWeight="SemiBold"
                       Margin="1,16,0,6" />

            <controls:SettingsCard Header="Phone"
                                   Description="Bookmarks, Tabs  ·  last sync 17s ago"
                                   IsClickEnabled="True">
                <controls:SettingsCard.HeaderIcon>
                    <SymbolIcon Symbol="CellPhone" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>

            <controls:SettingsCard Header="Personal iMac"
                                   Description="Bookmarks, Passkeys  ·  last sync 3h ago"
                                   IsClickEnabled="True">
                <controls:SettingsCard.HeaderIcon>
                    <SymbolIcon Symbol="Home" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>

            <TextBlock Text="About sync"
                       Foreground="{ThemeResource TextTertiary}"
                       FontSize="12"
                       CharacterSpacing="80"
                       FontWeight="SemiBold"
                       Margin="1,24,0,6" />

            <controls:SettingsCard Header="Loopback sync server"
                                   Description="All traffic runs on localhost today. chrome://sync-internals will surface the wire messages once that page is wired up.">
                <controls:SettingsCard.HeaderIcon>
                    <SymbolIcon Symbol="Sync" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>
        </StackPanel>
    </ScrollViewer>
</Page>
