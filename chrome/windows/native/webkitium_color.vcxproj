<?xml version="1.0" encoding="utf-8"?>
<!--
    Native C++ sidecar: compiles the portable browser/color/ sources into
    a standalone webkitium_color.dll that the managed shell loads via
    P/Invoke.  The source files live at ..\..\..\browser\color\ and are
    shared with the macOS SwiftPM build and the Android CMake build.
    One algorithm, three language bindings.
-->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{A6C4B2E1-3F8D-4F1A-9C2E-5B9F0D7A1234}</ProjectGuid>
    <RootNamespace>webkitium_color</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <PlatformToolset Condition="'$(VisualStudioVersion)' &gt;= '18.0'">v145</PlatformToolset>
    <PlatformToolset Condition="'$(VisualStudioVersion)' &lt; '18.0'">v143</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
    <UseDebugLibraries Condition="'$(Configuration)'=='Debug'">true</UseDebugLibraries>
    <UseDebugLibraries Condition="'$(Configuration)'=='Release'">false</UseDebugLibraries>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <PropertyGroup>
    <TargetName>webkitium_color</TargetName>
    <OutDir>$(SolutionDir)$(Platform)\$(Configuration)\native\</OutDir>
    <IntDir>$(Platform)\$(Configuration)\</IntDir>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <LanguageStandard>stdcpp17</LanguageStandard>
      <WarningLevel>Level4</WarningLevel>
      <AdditionalIncludeDirectories>$(ProjectDir)..\..\..\browser;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PreprocessorDefinitions Condition="'$(Configuration)'=='Debug'">_DEBUG;_WINDOWS;_USRDLL;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <PreprocessorDefinitions Condition="'$(Configuration)'=='Release'">NDEBUG;_WINDOWS;_USRDLL;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <RuntimeLibrary Condition="'$(Configuration)'=='Debug'">MultiThreadedDebugDLL</RuntimeLibrary>
      <RuntimeLibrary Condition="'$(Configuration)'=='Release'">MultiThreadedDLL</RuntimeLibrary>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
    </Link>
  </ItemDefinitionGroup>

  <ItemGroup>
    <!-- color/ -->
    <ClCompile Include="..\..\..\browser\color\ColorBridgeC.cc" />
    <ClCompile Include="..\..\..\browser\color\ColorRamp.cpp" />
    <ClCompile Include="..\..\..\browser\color\OklchColor.cpp" />
    <ClCompile Include="..\..\..\browser\color\SemanticPalette.cpp" />
    <ClCompile Include="webkitium_color_exports.cc" />

    <!-- extensions/ -->
    <ClCompile Include="..\..\..\browser\extensions\ExtensionBridgeC.cc" />
    <ClCompile Include="..\..\..\browser\extensions\ExtensionManifest.cpp" />
    <ClCompile Include="..\..\..\browser\extensions\ExtensionRegistry.cpp" />
    <ClCompile Include="webkitium_extensions_exports.cc" />

    <!-- sync/ (stub today; expands to LoopbackSyncServer when activated) -->
    <ClCompile Include="..\..\..\browser\sync\SyncBridgeC.cc" />
    <ClCompile Include="webkitium_sync_exports.cc" />

    <!-- webauthn/ -->
    <ClCompile Include="..\..\..\browser\core\Origin.cpp" />
    <ClCompile Include="..\..\..\browser\webauthn\WebAuthnBridgeC.cc" />
    <ClCompile Include="..\..\..\browser\webauthn\WebAuthnController.cpp" />
    <ClCompile Include="webkitium_webauthn_exports.cc" />
  </ItemGroup>

  <ItemGroup>
    <ClInclude Include="..\..\..\browser\color\ColorBridgeC.h" />
    <ClInclude Include="..\..\..\browser\color\ColorRamp.h" />
    <ClInclude Include="..\..\..\browser\color\OklchColor.h" />
    <ClInclude Include="..\..\..\browser\color\SemanticPalette.h" />
    <ClInclude Include="..\..\..\browser\core\Origin.h" />
    <ClInclude Include="..\..\..\browser\core\Result.h" />
    <ClInclude Include="..\..\..\browser\extensions\ExtensionBridgeC.h" />
    <ClInclude Include="..\..\..\browser\extensions\ExtensionManifest.h" />
    <ClInclude Include="..\..\..\browser\extensions\ExtensionRegistry.h" />
    <ClInclude Include="..\..\..\browser\sync\SyncBridgeC.h" />
    <ClInclude Include="..\..\..\browser\webauthn\WebAuthnBridgeC.h" />
    <ClInclude Include="..\..\..\browser\webauthn\WebAuthnController.h" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
