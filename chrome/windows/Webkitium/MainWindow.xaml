<Window
    x:Class="Webkitium.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:webview2="using:Microsoft.UI.Xaml.Controls"
    Title="Webkitium">

    <Grid x:Name="RootGrid" RowDefinitions="Auto,Auto,Auto,*">

        <!-- Chrome row: back / forward / reload + URL bar + bookmark star + more -->
        <CommandBar x:Name="ChromeBar" Grid.Row="0"
                    DefaultLabelPosition="Collapsed"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <CommandBar.Content>
                <Grid Padding="6,2,6,2" ColumnSpacing="0"
                      ColumnDefinitions="Auto,*">
                    <FontIcon x:Name="SecureLock" Grid.Column="0"
                              Glyph="&#xE72E;"
                              FontFamily="Segoe Fluent Icons"
                              FontSize="13"
                              Foreground="#3B82F6"
                              Visibility="Collapsed"
                              VerticalAlignment="Center"
                              Margin="6,0,6,0"
                              AutomationProperties.Name="Connection is secure"
                              Loaded="SecureLock_Loaded" />
                    <AutoSuggestBox x:Name="UrlBar" Grid.Column="1"
                                    PlaceholderText="Search or enter website"
                                    QueryIcon="Find"
                                    AutomationProperties.Name="Address bar"
                                    TextChanged="UrlBar_TextChanged"
                                    QuerySubmitted="UrlBar_QuerySubmitted"
                                    SuggestionChosen="UrlBar_SuggestionChosen"
                                    VerticalAlignment="Center"
                                    MinWidth="320" />
                </Grid>
            </CommandBar.Content>

            <CommandBar.PrimaryCommands>
                <AppBarButton x:Name="BookmarkButton"
                              Icon="OutlineStar"
                              Label="Bookmark"
                              AutomationProperties.Name="Bookmark this page"
                              Click="BookmarkButton_Click" />
                <AppBarButton x:Name="MoreButton"
                              Icon="More"
                              Label="More"
                              AutomationProperties.Name="More"
                              IsEnabled="False" />
            </CommandBar.PrimaryCommands>

            <CommandBar.SecondaryCommands>
                <AppBarButton x:Name="BackCommand"
                              Icon="Back" Label="Back"
                              AutomationProperties.Name="Back"
                              Click="Back_Click">
                    <AppBarButton.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Left" Modifiers="Menu" />
                    </AppBarButton.KeyboardAccelerators>
                </AppBarButton>
                <AppBarButton x:Name="ForwardCommand"
                              Icon="Forward" Label="Forward"
                              AutomationProperties.Name="Forward"
                              Click="Forward_Click">
                    <AppBarButton.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Right" Modifiers="Menu" />
                    </AppBarButton.KeyboardAccelerators>
                </AppBarButton>
                <AppBarButton x:Name="ReloadCommand"
                              Icon="Refresh" Label="Reload"
                              AutomationProperties.Name="Reload"
                              Click="Reload_Click">
                    <AppBarButton.KeyboardAccelerators>
                        <KeyboardAccelerator Key="R" Modifiers="Control" />
                    </AppBarButton.KeyboardAccelerators>
                </AppBarButton>
                <AppBarButton x:Name="FindCommand"
                              Icon="Find" Label="Find"
                              AutomationProperties.Name="Find in page"
                              Click="Find_Click">
                    <AppBarButton.KeyboardAccelerators>
                        <KeyboardAccelerator Key="F" Modifiers="Control" />
                    </AppBarButton.KeyboardAccelerators>
                </AppBarButton>
            </CommandBar.SecondaryCommands>
        </CommandBar>

        <!-- Bookmarks bar -->
        <ScrollViewer x:Name="BookmarksScroll" Grid.Row="1"
                      HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Disabled"
                      Padding="6,0,6,4"
                      Background="{ThemeResource SystemControlBackgroundChromeLowBrush}">
            <ItemsRepeater x:Name="BookmarksRepeater">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Horizontal" Spacing="4" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Find-on-page overlay -->
        <Border x:Name="FindOverlay" Grid.Row="2"
                Visibility="Collapsed"
                Background="{ThemeResource SystemControlAcrylicWindowBrush}"
                BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6,8,6">
            <Grid ColumnSpacing="6"
                  ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                <TextBox x:Name="FindBox" Grid.Column="0"
                         PlaceholderText="Find in page"
                         AutomationProperties.Name="Find in page"
                         KeyDown="FindBox_KeyDown"
                         TextChanged="FindBox_TextChanged"
                         VerticalContentAlignment="Center" />
                <TextBlock x:Name="FindMatchCount" Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="0/0" />
                <Button Grid.Column="2"
                        ToolTipService.ToolTip="Previous"
                        AutomationProperties.Name="Find previous"
                        Click="FindPrev_Click">
                    <FontIcon Glyph="&#xE70E;" />
                </Button>
                <Button Grid.Column="3"
                        ToolTipService.ToolTip="Next"
                        AutomationProperties.Name="Find next"
                        Click="FindNext_Click">
                    <FontIcon Glyph="&#xE70D;" />
                </Button>
                <Button Grid.Column="4"
                        ToolTipService.ToolTip="Close (Esc)"
                        AutomationProperties.Name="Close find"
                        Click="FindClose_Click">
                    <FontIcon Glyph="&#xE711;" />
                </Button>
            </Grid>
        </Border>

        <!-- Tab strip + per-tab WebView2 -->
        <controls:TabView x:Name="Tabs" Grid.Row="3"
                          IsAddTabButtonVisible="True"
                          CanDragTabs="True"
                          AddTabButtonClick="Tabs_AddTabButtonClick"
                          TabCloseRequested="Tabs_TabCloseRequested"
                          SelectionChanged="Tabs_SelectionChanged">
            <controls:TabView.KeyboardAccelerators>
                <KeyboardAccelerator Key="T" Modifiers="Control" Invoked="NewTab_Invoked" />
                <KeyboardAccelerator Key="W" Modifiers="Control" Invoked="CloseTab_Invoked" />
            </controls:TabView.KeyboardAccelerators>
        </controls:TabView>

    </Grid>
</Window>
