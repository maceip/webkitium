<Window
    x:Class="WebkitiumChrome.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">
    <Grid RowDefinitions="Auto,*">
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton Label="Back" Icon="Back" />
            <AppBarButton Label="Reload" Icon="Refresh" />
            <AppBarElementContainer>
                <TextBox x:Name="AddressBox" Width="560" PlaceholderText="Search or enter website name" Text="https://example.com" />
            </AppBarElementContainer>
            <AppBarButton Label="New Tab" Icon="Add" Click="NewTab_Click" />
        </CommandBar>

        <muxc:TabView
            x:Name="Tabs"
            Grid.Row="1"
            AddTabButtonClick="Tabs_AddTabButtonClick"
            TabCloseRequested="Tabs_TabCloseRequested"
            CanDragTabs="True"
            CanReorderTabs="True" />
    </Grid>
</Window>
