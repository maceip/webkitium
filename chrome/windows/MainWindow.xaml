<?xml version="1.0" encoding="utf-8"?>
<winex:WindowEx
    x:Class="Webkitium.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winex="using:WinUIEx"
    xmlns:views="using:Webkitium.Views"
    Title="Webkitium"
    PersistenceId="webkitium.main"
    MinWidth="640"
    MinHeight="400">

    <!--
        Mica backdrop via WindowEx.  Kind=Base so the user's brand tint
        shows up in discrete surfaces (omnibar, buttons) rather than
        being smeared across the whole window.
    -->
    <winex:WindowEx.Backdrop>
        <winex:MicaSystemBackdrop Kind="Base" />
    </winex:WindowEx.Backdrop>

    <!--
        Root layout. Row 0: TabView inside the title bar strip (the
        WinUIpad 2026 pattern). Row 1: NavigationView rail on the
        left (svrooij rail demo) with content Frame hosting omnibar
        over a web-content placeholder.
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar strip: TabView + trailing space for system chrome. -->
        <Grid Grid.Row="0" x:Name="TitleBarStrip">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>

            <TabView x:Name="TabStrip"
                     Grid.Column="0"
                     VerticalAlignment="Stretch"
                     TabWidthMode="Equal"
                     CloseButtonOverlayMode="Auto"
                     AddTabButtonClick="OnAddTab"
                     TabCloseRequested="OnTabClose">
                <TabView.TabItems>
                    <TabViewItem Header="New Tab" IsClosable="True" />
                </TabView.TabItems>
            </TabView>
        </Grid>

        <!-- Rail nav + content area. -->
        <NavigationView Grid.Row="1"
                        x:Name="Nav"
                        PaneDisplayMode="LeftCompact"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        IsSettingsVisible="False"
                        OpenPaneLength="240"
                        CompactPaneLength="48"
                        SelectionChanged="OnNavSelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Spaces"     Icon="Library"  Tag="spaces" />
                <NavigationViewItem Content="Tabs"       Icon="BrowsePhotos" Tag="tabs" IsSelected="True" />
                <NavigationViewItem Content="Downloads"  Icon="Download" Tag="downloads" />
                <NavigationViewItem Content="Extensions" Icon="Shop"     Tag="extensions" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Icon="Setting" Tag="settings" />
            </NavigationView.FooterMenuItems>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Omnibar band below the tab strip. -->
                <Grid Grid.Row="0" Padding="12,8,12,8">
                    <views:Omnibar MaxWidth="720" HorizontalAlignment="Center" />
                </Grid>

                <!-- Content surface placeholder. WebView2 / WebKit Windows lands here later. -->
                <Border Grid.Row="1"
                        Background="{ThemeResource SurfaceCanvas}"
                        CornerRadius="10"
                        Margin="12,0,12,12">
                    <TextBlock Text="Web content goes here"
                               Foreground="{ThemeResource TextTertiary}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>
        </NavigationView>
    </Grid>
</winex:WindowEx>
