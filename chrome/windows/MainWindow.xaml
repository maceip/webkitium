<?xml version="1.0" encoding="utf-8"?>
<winex:WindowEx
    x:Class="Webkitium.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winex="using:WinUIEx"
    xmlns:views="using:Webkitium.Views"
    Title="Webkitium"
    PersistenceId="webkitium.main"
    MinWidth="640"
    MinHeight="400">

    <winex:WindowEx.Backdrop>
        <winex:MicaSystemBackdrop Kind="Base" />
    </winex:WindowEx.Backdrop>

    <!--
        Layout after user feedback.
          Row 0: title-bar strip. TabView on the left (favicon-wide
          tabs, horizontal mode), explicit draggable filler in the
          middle, system controls reserve on the right.
          Row 1: content area. The selected tab's BrowserTab
          UserControl renders here. Each tab owns its own omnibar +
          WebView2.
          The vertical rail is removed; it returns only in vertical-
          tab mode (see BrowserStateModel.tabStripMode) via a future
          Ctrl+Shift+E toggle.
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0: title-bar strip. -->
        <Grid Grid.Row="0" x:Name="TitleBarStrip">
            <Grid.ColumnDefinitions>
                <!-- TabView width sizes to content (favicon-wide tabs). -->
                <ColumnDefinition Width="Auto" />
                <!-- Draggable filler. -->
                <ColumnDefinition Width="*" />
                <!-- Reserve for system min/max/close (drawn by OS). -->
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>

            <TabView x:Name="TabStrip"
                     Grid.Column="0"
                     VerticalAlignment="Stretch"
                     TabWidthMode="SizeToContent"
                     CloseButtonOverlayMode="OnPointerOver"
                     AddTabButtonClick="OnAddTab"
                     TabCloseRequested="OnTabClose"
                     SelectionChanged="OnTabSelectionChanged" />

            <!--
                Explicit drag filler. The Border is visually empty but
                is a first-class XAML element so SetTitleBar(...) on the
                containing strip still considers this whole row a drag
                region. InputNonClientPointerSource marks TabView
                internals as passthrough, so tab clicks work; everything
                else drags the window.
            -->
            <Border Grid.Column="1" Background="Transparent" />
        </Grid>

        <!-- Row 1: content frame for the active tab. -->
        <ContentControl x:Name="ActiveTabHost"
                        Grid.Row="1"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch" />
    </Grid>
</winex:WindowEx>
