<?xml version="1.0" encoding="utf-8"?>
<winex:WindowEx
    x:Class="Webkitium.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winex="using:WinUIEx"
    xmlns:views="using:Webkitium.Views"
    Title="Webkitium"
    PersistenceId="webkitium.main"
    MinWidth="640"
    MinHeight="400">

    <winex:WindowEx.Backdrop>
        <winex:MicaSystemBackdrop Kind="Base" />
    </winex:WindowEx.Backdrop>

    <!--
        Title-bar layout per design rules.
          Col 0: Omnibar (compact pill, leading edge).
          Col 1: TabView (favicon-wide tabs).
          Col 2: Drag filler (window-drag region between last tab
                 and the system-controls reserve).
          Col 3: System controls reserve (min/max/close drawn by OS).
        Row 1 below: ContentControl hosting the active tab's BrowserTab
        (just the WebView2 surface).
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" x:Name="TitleBarStrip">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>

            <!-- Compact omnibar at the leading edge. -->
            <Grid Grid.Column="0" Padding="8,6,4,6" VerticalAlignment="Center">
                <views:Omnibar x:Name="Omnibar" />
            </Grid>

            <!-- Tab strip. -->
            <TabView x:Name="TabStrip"
                     Grid.Column="1"
                     VerticalAlignment="Stretch"
                     TabWidthMode="SizeToContent"
                     CloseButtonOverlayMode="OnPointerOver"
                     AddTabButtonClick="OnAddTab"
                     TabCloseRequested="OnTabClose"
                     SelectionChanged="OnTabSelectionChanged" />

            <!-- Drag filler. -->
            <Border Grid.Column="2" Background="Transparent" />
        </Grid>

        <!-- Active tab content (WebView2 only; omnibar lives above). -->
        <ContentControl x:Name="ActiveTabHost"
                        Grid.Row="1"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch" />
    </Grid>
</winex:WindowEx>
